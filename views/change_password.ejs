<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Créer votre mot de passe – BRALIMA Supply Chain</title>
  <link rel="icon" type="image/png" href="/images/bralima-logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    (function() {
      const origWarn = console.warn;
      console.warn = function(...args) {
        if (args[0] && typeof args[0] === 'string' && args[0].includes('cdn.tailwindcss.com')) return;
        origWarn.apply(console, args);
      };
    })();
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .strength-bar { transition: width 0.3s ease, background-color 0.3s ease; }
  </style>
</head>
<body class="bg-gradient-to-br from-slate-100 to-blue-50 min-h-screen flex items-center justify-center p-4">

  <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row overflow-hidden w-full max-w-3xl">

    <!-- LEFT – Blue Panel -->
    <div class="w-full md:w-1/2 bg-gradient-to-br from-blue-700 via-blue-800 to-indigo-950 text-white p-8 flex flex-col justify-center items-center relative overflow-hidden rounded-t-3xl md:rounded-t-none md:rounded-l-3xl">

      <!-- Circle glow effects -->
      <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full pointer-events-none" style="background:rgba(59,130,246,0.2);filter:blur(40px)"></div>
      <div class="absolute -top-16 -left-16 w-72 h-72 rounded-full pointer-events-none" style="background:rgba(99,102,241,0.2);filter:blur(50px)"></div>

      <!-- Logo circle -->
      <div class="relative z-10 w-44 h-44 rounded-full flex items-center justify-center shadow-2xl" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2)">
        <div class="w-36 h-36 bg-white rounded-full flex items-center justify-center shadow-inner p-2">
          <img src="/images/bralima-logo.png" alt="BRALIMA Logo" class="w-28 h-28 object-contain rounded-xl">
        </div>
      </div>

      <!-- Brand name -->
      <div class="mt-6 text-center z-10">
        <h2 class="text-2xl font-extrabold tracking-widest uppercase">BRALIMA</h2>
        <p class="text-xs mt-1 uppercase tracking-widest font-medium" style="color:rgba(191,219,254,0.8)">Supply Chain Management</p>
      </div>

      <!-- Icon section -->
      <div class="mt-8 text-center z-10 px-4">
        <div class="w-16 h-16 bg-white bg-opacity-10 rounded-2xl flex items-center justify-center mx-auto mb-3">
          <i class="fas fa-shield-halved text-3xl text-blue-200"></i>
        </div>
        <p class="text-sm text-blue-100 leading-relaxed">Pour votre sécurité, veuillez créer un mot de passe personnel avant d'accéder à votre portail.</p>
      </div>
    </div>

    <!-- RIGHT – Password Form -->
    <div class="w-full md:w-1/2 bg-white p-8 md:p-10 flex flex-col justify-center">

      <!-- Header -->
      <div class="mb-6">
        <h1 class="text-xl md:text-2xl font-extrabold text-gray-800 leading-snug">Créez votre mot de passe</h1>
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-2">Première connexion — étape obligatoire</p>
      </div>

      <!-- Alert messages -->
      <% if (error) { %>
        <div class="mb-5 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm flex items-center gap-3">
          <i class="fas fa-exclamation-circle text-red-400 text-base flex-shrink-0"></i>
          <span><%= error %></span>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="mb-5 p-4 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl text-sm flex items-center gap-3">
          <i class="fas fa-check-circle text-emerald-400 text-base flex-shrink-0"></i>
          <span><%= success %></span>
        </div>
      <% } %>

      <!-- Info banner -->
      <div class="mb-5 p-3 bg-amber-50 border border-amber-200 text-amber-700 rounded-xl text-xs flex items-start gap-2">
        <i class="fas fa-info-circle mt-0.5 flex-shrink-0"></i>
        <span>Votre mot de passe temporaire a expiré. Veuillez choisir un nouveau mot de passe d'au moins <strong>8 caractères</strong>.</span>
      </div>

      <!-- Form -->
      <form method="POST" action="/change-password" class="space-y-5" id="changePasswordForm">

        <!-- New password -->
        <div class="relative">
          <label for="nouveau_mot_de_passe" class="absolute px-1.5 bg-white text-xs font-semibold text-gray-500 z-10" style="top:-10px;left:14px">
            Nouveau mot de passe<span class="text-red-500">*</span>
          </label>
          <div class="border border-gray-300 rounded-xl px-4 py-3.5 flex items-center justify-between focus-within:ring-2 focus-within:ring-blue-600 focus-within:border-transparent bg-gray-50 hover:bg-white transition-all duration-200">
            <input type="password" name="nouveau_mot_de_passe" id="nouveau_mot_de_passe" required minlength="8"
              class="w-full bg-transparent border-none outline-none p-0 text-sm text-gray-800 placeholder-gray-400"
              placeholder="Au moins 8 caractères"
              oninput="updateStrength(this.value)">
            <button type="button" onclick="toggleVis('nouveau_mot_de_passe', this)" class="ml-2 text-gray-400 hover:text-gray-600 flex-shrink-0">
              <i class="fas fa-eye text-sm"></i>
            </button>
          </div>
          <!-- Strength bar -->
          <div class="mt-2 h-1.5 bg-gray-200 rounded-full overflow-hidden">
            <div id="strengthBar" class="h-full strength-bar rounded-full w-0 bg-red-400"></div>
          </div>
          <p id="strengthLabel" class="text-xs text-gray-400 mt-1"></p>
        </div>

        <!-- Confirm password -->
        <div class="relative">
          <label for="confirmation" class="absolute px-1.5 bg-white text-xs font-semibold text-gray-500 z-10" style="top:-10px;left:14px">
            Confirmer le mot de passe<span class="text-red-500">*</span>
          </label>
          <div class="border border-gray-300 rounded-xl px-4 py-3.5 flex items-center justify-between focus-within:ring-2 focus-within:ring-blue-600 focus-within:border-transparent bg-gray-50 hover:bg-white transition-all duration-200">
            <input type="password" name="confirmation" id="confirmation" required
              class="w-full bg-transparent border-none outline-none p-0 text-sm text-gray-800 placeholder-gray-400"
              placeholder="Répétez le mot de passe"
              oninput="checkMatch()">
            <button type="button" onclick="toggleVis('confirmation', this)" class="ml-2 text-gray-400 hover:text-gray-600 flex-shrink-0">
              <i class="fas fa-eye text-sm"></i>
            </button>
          </div>
          <p id="matchLabel" class="text-xs mt-1 text-gray-400"></p>
        </div>

        <!-- Submit -->
        <button type="submit" id="submitBtn"
          class="w-full bg-blue-700 hover:bg-blue-800 text-white font-bold py-3.5 rounded-xl shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 text-sm tracking-wide flex items-center justify-center gap-2">
          <i class="fas fa-check-circle"></i>
          Enregistrer mon mot de passe
        </button>

      </form>

      <!-- Footer -->
      <div class="mt-6 pt-4 border-t border-gray-100 text-center">
        <a href="/logout" class="text-xs text-gray-400 hover:text-blue-600 transition-colors">
          <i class="fas fa-arrow-left mr-1"></i>Se déconnecter
        </a>
      </div>

    </div>
  </div>

  <script>
    function toggleVis(fieldId, btn) {
      const input = document.getElementById(fieldId);
      const icon = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }

    function updateStrength(value) {
      const bar = document.getElementById('strengthBar');
      const label = document.getElementById('strengthLabel');
      let score = 0;
      if (value.length >= 8) score++;
      if (value.length >= 12) score++;
      if (/[A-Z]/.test(value)) score++;
      if (/[0-9]/.test(value)) score++;
      if (/[^A-Za-z0-9]/.test(value)) score++;

      const levels = [
        { w: '0%', color: 'bg-gray-200', text: '' },
        { w: '25%', color: 'bg-red-400', text: 'Très faible' },
        { w: '50%', color: 'bg-orange-400', text: 'Faible' },
        { w: '75%', color: 'bg-yellow-400', text: 'Moyen' },
        { w: '90%', color: 'bg-blue-400', text: 'Fort' },
        { w: '100%', color: 'bg-emerald-500', text: 'Très fort' },
      ];
      const lvl = value.length === 0 ? 0 : Math.min(score, 5);
      bar.style.width = levels[lvl].w;
      bar.className = `h-full strength-bar rounded-full ${levels[lvl].color}`;
      label.textContent = levels[lvl].text;
      label.className = `text-xs mt-1 ${lvl >= 4 ? 'text-emerald-600' : 'text-gray-400'}`;
    }

    function checkMatch() {
      const pwd = document.getElementById('nouveau_mot_de_passe').value;
      const conf = document.getElementById('confirmation').value;
      const label = document.getElementById('matchLabel');
      if (conf.length === 0) {
        label.textContent = '';
      } else if (pwd === conf) {
        label.textContent = '✓ Les mots de passe correspondent';
        label.className = 'text-xs mt-1 text-emerald-600';
      } else {
        label.textContent = '✗ Les mots de passe ne correspondent pas';
        label.className = 'text-xs mt-1 text-red-500';
      }
    }
  </script>

</body>
</html>
