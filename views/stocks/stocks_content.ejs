<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Gestion des Stocks</h1>
    <p class="text-gray-600 mt-1">Consultez et gérez l'inventaire des matières premières</p>
  </div>

  <!-- Search and Filters -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex flex-wrap gap-4 items-end">
      <div class="flex-1 min-w-[200px]">
        <input type="text" placeholder="Rechercher une matière première..." class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="flex-1 min-w-[200px]">
        <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Tous les entrepôts</option>
          <option value="principal">Entrepôt Principal</option>
          <option value="secondaire">Entrepôt Secondaire</option>
        </select>
      </div>
      <div class="flex-1 min-w-[200px]">
        <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Tous les statuts</option>
          <option value="normal">Normal</option>
          <option value="alerte">Alerte</option>
          <option value="critique">Critique</option>
        </select>
      </div>
      <button class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
        <i class="fas fa-search mr-2"></i>Filtrer
      </button>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-boxes text-blue-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900"><%= stocks.length %></h3>
      <p class="text-sm text-gray-600">Total stocks</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-check-circle text-green-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= stocks.filter(s => s.qtedisponible > 100).length %>
      </h3>
      <p class="text-sm text-gray-600">Stocks normaux</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-exclamation-triangle text-amber-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= stocks.filter(s => s.qtedisponible > 20 && s.qtedisponible <= 100).length %>
      </h3>
      <p class="text-sm text-gray-600">Alertes stock</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-times-circle text-red-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= stocks.filter(s => s.qtedisponible <= 20).length %>
      </h3>
      <p class="text-sm text-gray-600">Stocks critiques</p>
    </div>
  </div>

  <!-- Stocks Table -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <div class="flex justify-between items-center">
        <h2 class="text-lg font-medium text-gray-900">Inventaire des stocks</h2>
        <div class="flex space-x-2">
          <button class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
            <i class="fas fa-download mr-2"></i>Exporter
          </button>
          <button class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            <i class="fas fa-print mr-2"></i>Imprimer
          </button>
        </div>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Matière première</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code-barres</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantité</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unité</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Entrepôt</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Dernière mise à jour</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% stocks.forEach(function(stock) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10">
                    <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center">
                      <span class="text-gray-600 font-medium text-xs">
                        <%= stock.libellé ? stock.libellé.charAt(0).toUpperCase() : 'M' %>
                      </span>
                    </div>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900"><%= stock.libellé || 'Non défini' %></div>
                    <div class="text-xs text-gray-500 flex flex-wrap gap-2 items-center mt-0.5">
                      <span><%= stock.description || '' %></span>
                      <% if (stock.lotnumero) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">Lot: <%= stock.lotnumero %></span>
                      <% } %>
                      <% if (stock.dateperemption) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">Exp: <%= new Date(stock.dateperemption).toLocaleDateString('fr-FR') %></span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900">
                  <% if (stock.codebarres) { %>
                    <span class="font-mono bg-gray-100 px-2 py-1 rounded"><%= stock.codebarres %></span>
                  <% } else { %>
                    <span class="text-gray-400">---</span>
                  <% } %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-lg font-bold <%= stock.qtedisponible <= 20 ? 'text-red-600' : stock.qtedisponible <= 100 ? 'text-amber-600' : 'text-green-600' %>">
                  <%= stock.qtedisponible || 0 %> Kg
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= stock.unite || 'KG' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= stock.identret || 'Principal' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if (stock.qtedisponible <= 20) { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Critique</span>
                <% } else if (stock.qtedisponible <= 100) { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800">Alerte</span>
                <% } else { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Normal</span>
                <% } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= stock.datemaj ? new Date(stock.datemaj).toLocaleDateString('fr-FR') : '---' %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    
    <!-- Pagination -->
    <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
      <div class="flex-1 flex justify-between sm:hidden">
        <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Précédent</a>
        <a href="#" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Suivant</a>
      </div>
      <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
        <div>
          <p class="text-sm text-gray-700">
            Affichage de <span class="font-medium">1</span> à <span class="font-medium"><%= stocks.length %></span> sur <span class="font-medium"><%= stocks.length %></span> résultats
          </p>
        </div>
        <div>
          <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
            <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
              <i class="fas fa-chevron-left"></i>
            </a>
            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-blue-50 text-sm font-medium text-blue-600">1</a>
            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">2</a>
            <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
              <i class="fas fa-chevron-right"></i>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>
