<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Commandes</h1>
      <p class="text-gray-600 mt-1">Gestion des commandes fournisseurs</p>
    </div>
    <a href="/commandes/create" class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
      <i class="fas fa-plus-circle"></i>
      <span>Nouvelle commande</span>
    </a>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-clock text-blue-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= commandes.filter(c => c.statut === 'en_attente').length %>
      </h3>
      <p class="text-sm text-gray-600">En attente</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-eye text-amber-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= commandes.filter(c => c.statut === 'approuvee').length %>
      </h3>
      <p class="text-sm text-gray-600">Approuvées</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-check-circle text-green-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= commandes.filter(c => c.statut === 'en_cours').length %>
      </h3>
      <p class="text-sm text-gray-600">En cours</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-check-double text-purple-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900">
        <%= commandes.filter(c => c.statut === 'livree').length %>
      </h3>
      <p class="text-sm text-gray-600">Livrées</p>
    </div>
  </div>

  <!-- Search and Filters -->
  <div class="bg-white rounded-lg shadow p-4">
    <div class="flex flex-wrap gap-4 items-end">
      <div class="flex-1 min-w-[200px]">
        <input type="text" id="commandeSearch" placeholder="Rechercher une commande..." class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="flex-1 min-w-[200px]">
        <select id="filterStatut" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Tous les statuts</option>
          <option value="en_attente">En attente</option>
          <option value="approuvee">Approuvée</option>
          <option value="en_cours">En cours</option>
          <option value="en_cours_de_livraison">En cours de livraison</option>
          <option value="livree">Livrée</option>
          <option value="refusee">Refusée</option>
        </select>
      </div>
      <div class="flex-1 min-w-[200px]">
        <select id="filterFournisseur" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Tous les fournisseurs</option>
          <% 
          const uniqueSuppliers = [];
          const seenSupplierIds = new Set();
          commandes.forEach(function(c) {
            if (c.idfournisseur && c.raisonsocial && !seenSupplierIds.has(c.idfournisseur)) {
              seenSupplierIds.add(c.idfournisseur);
              uniqueSuppliers.push({ id: c.idfournisseur, name: c.raisonsocial });
            }
          });
          uniqueSuppliers.sort((a, b) => a.name.localeCompare(b.name));
          %>
          <% uniqueSuppliers.forEach(function(s) { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% }); %>
        </select>
      </div>
      <button id="btnFiltrer" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
        <i class="fas fa-search mr-2"></i>Filtrer
      </button>
    </div>
  </div>

  <!-- Orders Table -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <div class="flex justify-between items-center">
        <h2 class="text-lg font-medium text-gray-900">Liste des commandes</h2>
        <div class="flex space-x-2">
          <button id="btnExporter" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
            <i class="fas fa-download mr-2"></i>Exporter
          </button>
          <button id="btnImprimer" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            <i class="fas fa-print mr-2"></i>Imprimer
          </button>
        </div>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Référence</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fournisseur</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date de livraison</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Montant</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% commandes.forEach(function(commande) { %>
            <tr class="hover:bg-gray-50 commande-row" data-idfournisseur="<%= commande.idfournisseur %>" data-statut="<%= commande.statut %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <a href="/commandes/<%= commande.idcommande %>" class="text-blue-600 hover:text-blue-800">
                    <%= commande.reference %>
                  </a>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= commande.raisonsocial || 'Non défini' %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= commande.deleidellivraison ? new Date(commande.deleidellivraison).toLocaleDateString('fr-FR') : '---' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if (commande.total) { %>
                  <%= formatMoney(commande.total) %>
                <% } else { %>
                  <span class="text-gray-400">---</span>
                <% } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if (commande.statut === 'en_attente') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">En attente</span>
                <% } else if (commande.statut === 'approuvee') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800">Approuvée</span>
                <% } else if (commande.statut === 'en_cours') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">En cours</span>
                <% } else if (commande.statut === 'en_cours_de_livraison') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-200 text-amber-900">En cours de livraison</span>
                <% } else if (commande.statut === 'livree') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">Livrée</span>
                <% } else { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800"><%= commande.statut %></span>
                <% } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex space-x-2">
                  <a href="/commandes/<%= commande.idcommande %>" class="text-blue-600 hover:text-blue-900">Voir</a>
                  <% if (commande.statut === 'en_attente') { %>
                    <form method="POST" action="/commandes/<%= commande.idcommande %>/statut" class="inline">
                      <input type="hidden" name="statut" value="approuvee">
                      <button type="submit" class="text-green-600 hover:text-green-900">Approuver</button>
                    </form>
                  <% } %>
                  <% if (commande.statut === 'approuvee') { %>
                    <form method="POST" action="/commandes/<%= commande.idcommande %>/statut" class="inline">
                      <input type="hidden" name="statut" value="en_cours">
                      <button type="submit" class="text-amber-600 hover:text-amber-900">Démarrer</button>
                    </form>
                  <% } %>
                  <% if (commande.statut === 'en_attente' || commande.statut === 'approuvee') { %>
                    <form method="POST" action="/commandes/<%= commande.idcommande %>/relancer" class="inline">
                      <button type="submit" class="text-red-600 hover:text-red-900">Relancer</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    
    <!-- Pagination -->
    <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
      <div class="flex-1 flex justify-between sm:hidden">
        <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Précédent</a>
        <a href="#" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Suivant</a>
      </div>
      <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
        <div>
          <p class="text-sm text-gray-700">
            Affichage de <span class="font-medium">1</span> à <span class="font-medium"><%= commandes.length %></span> sur <span class="font-medium"><%= commandes.length %></span> résultats
          </p>
        </div>
        <div>
          <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
            <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
              <i class="fas fa-chevron-left"></i>
            </a>
            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-blue-50 text-sm font-medium text-blue-600">1</a>
            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">2</a>
            <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
              <i class="fas fa-chevron-right"></i>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Filtrage des commandes
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('commandeSearch');
  const statusSelect = document.getElementById('filterStatut');
  const fournisseurSelect = document.getElementById('filterFournisseur');
  const filterButton = document.getElementById('btnFiltrer');
  const exportButton = document.getElementById('btnExporter');
  const printButton = document.getElementById('btnImprimer');
  const tableRows = document.querySelectorAll('.commande-row');

  // Fonction de filtrage
  function filterCommandes() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const statusFilter = statusSelect.value;
    const fournisseurFilter = fournisseurSelect.value;

    tableRows.forEach(row => {
      const reference = row.cells[0].textContent.toLowerCase().trim();
      const fournisseur = row.cells[1].textContent.toLowerCase().trim();
      const statutAttr = row.getAttribute('data-statut') || '';
      const idfournisseurAttr = row.getAttribute('data-idfournisseur') || '';
      
      const matchesSearch = !searchTerm || 
                            reference.includes(searchTerm) || 
                            fournisseur.includes(searchTerm);
      const matchesStatus = !statusFilter || statutAttr === statusFilter;
      const matchesFournisseur = !fournisseurFilter || idfournisseurAttr === fournisseurFilter;

      if (matchesSearch && matchesStatus && matchesFournisseur) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });

    // Mettre à jour le compteur de résultats
    updateResultCount();
  }

  // Mettre à jour le compteur de résultats
  function updateResultCount() {
    const visibleRows = Array.from(tableRows).filter(row => row.style.display !== 'none');
    const countElement = document.querySelector('p.text-sm.text-gray-700');
    if (countElement) {
      const start = visibleRows.length > 0 ? 1 : 0;
      countElement.innerHTML = `Affichage de <span class="font-medium">${start}</span> à <span class="font-medium">${visibleRows.length}</span> sur <span class="font-medium">${tableRows.length}</span> résultats`;
    }
  }

  // Ajouter les écouteurs d'événements
  searchInput.addEventListener('input', filterCommandes);
  statusSelect.addEventListener('change', filterCommandes);
  fournisseurSelect.addEventListener('change', filterCommandes);
  
  if (filterButton) {
    filterButton.addEventListener('click', function(e) {
      e.preventDefault();
      filterCommandes();
    });
  }

  // Fonction d'exportation
  if (exportButton) {
    exportButton.addEventListener('click', function(e) {
      e.preventDefault();
      exportToExcel();
    });
  }

  // Fonction d'impression
  if (printButton) {
    printButton.addEventListener('click', function(e) {
      e.preventDefault();
      printCommandes();
    });
  }

  // Exporter vers Excel/CSV
  function exportToExcel() {
    const visibleRows = Array.from(tableRows).filter(row => row.style.display !== 'none');
    
    if (visibleRows.length === 0) {
      alert('Aucune commande à exporter');
      return;
    }

    // Créer le contenu CSV avec BOM pour Excel
    let csvContent = "\uFEFFRéférence,Fournisseur,Date de livraison,Montant,Statut\n";
    
    visibleRows.forEach(row => {
      const cells = row.cells;
      const reference = cells[0].textContent.trim();
      const fournisseur = cells[1].textContent.trim();
      const dateLivraison = cells[2].textContent.trim();
      const montant = cells[3].textContent.trim();
      const statut = cells[4].textContent.trim();
      
      csvContent += `"${reference}","${fournisseur}","${dateLivraison}","${montant}","${statut}"\n`;
    });

    // Créer et télécharger le fichier
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    
    link.setAttribute('href', url);
    link.setAttribute('download', `commandes_${new Date().toISOString().split('T')[0]}.csv`);
    link.style.visibility = 'hidden';
    
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // Fonction d'impression
  function printCommandes() {
    const visibleRows = Array.from(tableRows).filter(row => row.style.display !== 'none');
    
    if (visibleRows.length === 0) {
      alert('Aucune commande à imprimer');
      return;
    }

    // Créer une fenêtre d'impression
    const printWindow = window.open('', '_blank');
    
    const printContent = `
      <!DOCTYPE html>
      <html>
      <head>
        <title>Impression des Commandes</title>
        <style>
          body { font-family: Arial, sans-serif; margin: 20px; }
          h1 { color: #333; border-bottom: 2px solid #333; padding-bottom: 10px; }
          table { width: 100%; border-collapse: collapse; margin-top: 20px; }
          th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
          th { background-color: #f2f2f2; font-weight: bold; }
          tr:nth-child(even) { background-color: #f9f9f9; }
          .footer { margin-top: 30px; font-size: 12px; color: #666; }
        </style>
      </head>
      <body>
        <h1>Liste des Commandes</h1>
        <p>Généré le: ${new Date().toLocaleDateString('fr-FR')} à ${new Date().toLocaleTimeString('fr-FR')}</p>
        <table>
          <thead>
            <tr>
              <th>Référence</th>
              <th>Fournisseur</th>
              <th>Date de livraison</th>
              <th>Montant</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            ${visibleRows.map(row => {
              const cells = row.cells;
              return `
                <tr>
                  <td>${cells[0].textContent.trim()}</td>
                  <td>${cells[1].textContent.trim()}</td>
                  <td>${cells[2].textContent.trim()}</td>
                  <td>${cells[3].textContent.trim()}</td>
                  <td>${cells[4].textContent.trim()}</td>
                </tr>
              `;
            }).join('')}
          </tbody>
        </table>
        <div class="footer">
          <p>Total: ${visibleRows.length} commande(s)</p>
        </div>
      </body>
      </html>
    `;
    
    printWindow.document.write(printContent);
    printWindow.document.close();
    printWindow.focus();
    
    // Imprimer après un court délai pour s'assurer que le contenu est chargé
    setTimeout(() => {
      printWindow.print();
      printWindow.close();
    }, 500);
  }

  // Initialiser le compteur
  updateResultCount();
});
</script>
