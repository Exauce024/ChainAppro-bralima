<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Créer une nouvelle commande</h1>
    <p class="text-gray-600 mt-1">Remplissez les informations pour créer une commande fournisseur</p>
  </div>

  <!-- Form Card -->
  <form method="POST" action="/commandes/create" class="space-y-6">
    <!-- General Information Card -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-6 border-b border-gray-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
            <i class="fas fa-file-alt text-blue-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800">Informations de la commande</h3>
            <p class="text-sm text-gray-500">Détails généraux de la commande</p>
          </div>
        </div>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Référence de la commande</label>
            <div class="flex items-center space-x-2">
              <input type="text" id="reference" name="reference" required class="flex-1 px-3 py-2 border border-gray-300 rounded-lg bg-gray-50" readonly>
              <button type="button" onclick="generateReference()" class="px-3 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                <i class="fas fa-sync-alt mr-2"></i>Générer
              </button>
            </div>
            <p class="text-xs text-gray-500 mt-1">Référence générée automatiquement (format: CMD-YYYY-NNN)</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Date de livraison souhaitée</label>
            <input type="date" name="deleidellivraison" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>
        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">Fournisseur</label>
          <select name="idfournisseur" id="supplierSelect" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Sélectionner un fournisseur</option>
            <% fournisseurs.forEach(function(fournisseur) { %>
              <option value="<%= fournisseur.idfournisseur %>"><%= fournisseur.raisonsocial %></option>
            <% }); %>
          </select>
        </div>
      </div>
    </div>

    <!-- Order Lines Card -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-6 border-b border-gray-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
            <i class="fas fa-list text-green-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800">Lignes de commande</h3>
            <p class="text-sm text-gray-500">Ajoutez les matières premières à commander</p>
          </div>
        </div>
      </div>
      <div class="p-6">
        <div id="orderLines" class="space-y-4">
          <!-- First line (always visible) -->
          <div class="order-line bg-gray-50 p-4 rounded-lg border border-gray-200">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Matière première</label>
                <select name="lignes[0][idmp]" id="materialSelect" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                  <option value="">Sélectionner une matière</option>
                  <% matieres.forEach(function(matiere) { %>
                    <option value="<%= matiere.idmp %>"><%= matiere.libellé %></option>
                  <% }); %>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Quantité</label>
                <input type="number" name="lignes[0][qtecommande]" id="quantityInput" required min="1" step="0.01" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0.00">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Prix unitaire</label>
                <input type="number" name="lignes[0][prixunitaire]" id="priceInput" required min="0" readonly class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-gray-100 focus:outline-none" placeholder="Sélectionnez un fournisseur">
              </div>
            </div>
          </div>
        </div>

        <!-- Live Total Display -->
        <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-100 flex justify-between items-center">
          <span class="text-sm font-medium text-blue-800">Total estimé :</span>
          <span id="liveTotal" class="text-xl font-bold text-blue-900">0,00 FC</span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex justify-end space-x-4">
      <a href="/commandes" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
        <i class="fas fa-times mr-2"></i>Annuler
      </a>
      <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        <i class="fas fa-check mr-2"></i>Créer la commande
      </button>
    </div>
  </form>
</div>

<script>
const supplierRelations = <%- JSON.stringify(relations) %>;

document.addEventListener('DOMContentLoaded', function() {
  generateReference();

  const supplierSelect = document.getElementById('supplierSelect');
  const materialSelect = document.getElementById('materialSelect');
  const quantityInput = document.getElementById('quantityInput');
  const priceInput = document.getElementById('priceInput');
  const liveTotal = document.getElementById('liveTotal');

  function updateOrderLine() {
    const idfournisseur = supplierSelect.value;
    
    if (!idfournisseur) {
      // Clear materials and reset price/total
      materialSelect.innerHTML = '<option value="">Sélectionner une matière</option>';
      priceInput.value = '';
      priceInput.placeholder = 'Sélectionnez un fournisseur';
      updateTotal();
      return;
    }

    // Filter relations for this supplier
    const relations = supplierRelations.filter(r => Number(r.idfournisseur) === Number(idfournisseur));
    
    if (relations.length === 0) {
      materialSelect.innerHTML = '<option value="">Aucune matière configurée pour ce fournisseur</option>';
      priceInput.value = '';
      priceInput.placeholder = 'Pas de tarif configuré';
      updateTotal();
      return;
    }

    // Populate materials select
    let optionsHtml = '<option value="">Sélectionner une matière</option>';
    relations.forEach(r => {
      optionsHtml += `<option value="${r.idmp}" data-price="${r.prix_kg}">${r.libelle}</option>`;
    });
    materialSelect.innerHTML = optionsHtml;

    // Auto-select if there's only one material
    if (relations.length === 1) {
      materialSelect.value = relations[0].idmp;
      priceInput.value = relations[0].prix_kg;
    } else {
      priceInput.value = '';
      priceInput.placeholder = 'Sélectionnez une matière';
    }

    updateTotal();
  }

  function handleMaterialChange() {
    const selectedOption = materialSelect.options[materialSelect.selectedIndex];
    if (selectedOption && selectedOption.value) {
      const price = selectedOption.getAttribute('data-price');
      priceInput.value = price;
    } else {
      priceInput.value = '';
      priceInput.placeholder = 'Sélectionnez une matière';
    }
    updateTotal();
  }

  function updateTotal() {
    const qty = parseFloat(quantityInput.value) || 0;
    const price = parseFloat(priceInput.value) || 0;
    const total = qty * price;
    
    // Format using Congolese Franc format
    liveTotal.textContent = total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' FC';
  }

  // Listeners
  supplierSelect.addEventListener('change', updateOrderLine);
  materialSelect.addEventListener('change', handleMaterialChange);
  quantityInput.addEventListener('input', updateTotal);
  
  // Trigger initial update in case of form reload
  if (supplierSelect.value) {
    updateOrderLine();
  }
});

// Generate reference function
function generateReference() {
  const year = new Date().getFullYear();
  const random = Math.floor(Math.random() * 900) + 100; // 3-digit random number
  const reference = `CMD-${year}-${random}`;
  document.getElementById('reference').value = reference;
}
</script>
