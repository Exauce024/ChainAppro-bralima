<%
var content = `
<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-3xl font-bold text-slate-800">Commandes</h2>
      <p class="text-slate-500 mt-1">Gestion des commandes fournisseurs</p>
    </div>
    <a href="/commandes/create" class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
      <i class="fas fa-plus-circle"></i>
      <span>Nouvelle commande</span>
    </a>
  </div>

  <!-- Orders Table -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-shopping-cart text-blue-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-slate-800">Liste des commandes</h3>
          <p class="text-sm text-slate-500">${commandes.length} commande(s) trouvée(s)</p>
        </div>
      </div>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Référence</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Fournisseur</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date création</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">`;

commandes.forEach(function(cmd) {
  var statusColor = '';
  var statusBg = '';
  
  switch(cmd.statut) {
    case 'en_attente':
      statusColor = 'text-amber-800';
      statusBg = 'bg-amber-100';
      break;
    case 'approuvee':
      statusColor = 'text-blue-800';
      statusBg = 'bg-blue-100';
      break;
    case 'en_cours':
      statusColor = 'text-purple-800';
      statusBg = 'bg-purple-100';
      break;
    case 'livree':
      statusColor = 'text-emerald-800';
      statusBg = 'bg-emerald-100';
      break;
    case 'annulee':
      statusColor = 'text-red-800';
      statusBg = 'bg-red-100';
      break;
    default:
      statusColor = 'text-slate-800';
      statusBg = 'bg-slate-100';
  }

  content += `
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <span class="font-mono font-medium text-slate-800">${cmd.reference}</span>
            </td>
            <td class="px-6 py-4 text-slate-600">${cmd.raisonsocial || 'N/A'}</td>
            <td class="px-6 py-4 text-slate-600">${cmd.datecreation}</td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium ${statusBg} ${statusColor}">
                <span class="w-2 h-2 rounded-full ${statusBg.replace('100', '500')} mr-2"></span>
                ${cmd.statut}
              </span>
            </td>
            <td class="px-6 py-4">
              <a href="/commandes/${cmd.idcommande}" class="inline-flex items-center space-x-1 text-blue-600 hover:text-blue-800 font-medium text-sm transition-colors">
                <i class="fas fa-eye"></i>
                <span>Voir détails</span>
              </a>
            </td>
          </tr>`;
});

content += `
        </tbody>
      </table>
    </div>
    
    ${commandes.length === 0 ? `
    <div class="p-12 text-center">
      <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-inbox text-slate-400 text-2xl"></i>
      </div>
      <p class="text-slate-500">Aucune commande trouvée</p>
      <a href="/commandes/create" class="inline-block mt-4 text-blue-600 hover:text-blue-800 font-medium">
        Créer votre première commande
      </a>
    </div>
    ` : ''}
  </div>
</div>
`;
%>
<%- include('../layout', { body: content }) %>
