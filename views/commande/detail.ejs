<%
var content = `
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h2 class="text-3xl font-bold text-slate-800">Commande n°${commande.idcommande} - ${commande.raisonsocial}</h2>
    <p class="text-slate-500 mt-1">Détails de la commande fournisseur</p>
  </div>

  <!-- Order Info Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-info-circle text-blue-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-slate-800">Informations générales</h3>
          <p class="text-sm text-slate-500">Statut et détails</p>
        </div>
      </div>
    </div>
    
    <div class="p-6 space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-slate-500">Statut</p>
          <p class="text-lg font-semibold text-slate-800">${commande.statut}</p>
        </div>
        <div>
          <p class="text-sm text-slate-500">Référence</p>
          <p class="text-lg font-semibold text-slate-800">${commande.reference || 'N/A'}</p>
        </div>
      </div>
      
      <div>
        <p class="text-sm text-slate-500">Détails des lignes</p>
        <p class="text-slate-800 mt-1">${commande.details_lignes || 'Aucun détail disponible'}</p>
      </div>
    </div>
  </div>

  <!-- Status Change Form -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-exchange-alt text-emerald-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-slate-800">Changer le statut</h3>
          <p class="text-sm text-slate-500">Mettre à jour l'état de la commande</p>
        </div>
      </div>
    </div>
    
    <form method="POST" action="/commandes/${commande.idcommande}/statut" class="p-6 space-y-4">
      <div>
        <label for="statut" class="block text-sm font-medium text-slate-700 mb-2">Nouveau statut</label>
        <select name="statut" id="statut" 
          class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white">
          <option value="approuvee">Approuvée</option>
          <option value="refusee">Refusée</option>
          <option value="livree">Livrée</option>
        </select>
      </div>
      
      <div>
        <label for="motifrefus" class="block text-sm font-medium text-slate-700 mb-2">Motif du refus (si refus)</label>
        <input type="text" name="motifrefus" id="motifrefus" 
          class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
          placeholder="Expliquez le motif du refus">
      </div>
      
      <button type="submit" 
        class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
        <i class="fas fa-check"></i>
        <span>Changer le statut</span>
      </button>
    </form>
  </div>

  <!-- Actions -->
  <div class="flex space-x-4">
    <button id="relancerBtn" 
      class="inline-flex items-center space-x-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
      <i class="fas fa-envelope"></i>
      <span>Relancer le fournisseur par email</span>
    </button>
    
    <a href="/commandes" 
      class="inline-flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-3 rounded-xl transition-all duration-200">
      <i class="fas fa-arrow-left"></i>
      <span>Retour à la liste</span>
    </a>
  </div>
</div>

<script>
async function relancer(id) {
  const res = await fetch('/commandes/' + id + '/relancer', { method: 'POST' });
  const data = await res.json();
  alert(data.message || 'Relance envoyée');
}

document.getElementById('relancerBtn').onclick = function() {
  relancer(${commande.idcommande});
};
</script>
`;
%>
<%- include('../layout', { body: content }) %>
