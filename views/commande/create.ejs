<%
var content = `
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h2 class="text-3xl font-bold text-slate-800">Créer une nouvelle commande</h2>
    <p class="text-slate-500 mt-1">Remplissez les informations pour créer une commande fournisseur</p>
  </div>

  <!-- Form Card -->
  <form method="POST" action="/commandes/create" class="space-y-6">
    <!-- General Information Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="p-6 border-b border-slate-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
            <i class="fas fa-file-alt text-blue-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-800">Informations de la commande</h3>
            <p class="text-sm text-slate-500">Détails généraux</p>
          </div>
        </div>
      </div>
      
      <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="reference" class="block text-sm font-medium text-slate-700 mb-2">Référence</label>
            <input type="text" name="reference" id="reference" required 
              class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
              placeholder="CMD-2026-001">
          </div>
          
          <div>
            <label for="deleidellivraison" class="block text-sm font-medium text-slate-700 mb-2">Date livraison souhaitée</label>
            <input type="date" name="deleidellivraison" id="deleidellivraison" required 
              class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
          </div>
        </div>
        
        <div>
          <label for="idfournisseur" class="block text-sm font-medium text-slate-700 mb-2">Fournisseur</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fas fa-truck text-slate-400"></i>
            </div>
            <select name="idfournisseur" id="idfournisseur" required 
              class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 appearance-none bg-white">
              <option value="">Sélectionner un fournisseur</option>`;

fournisseurs.forEach(function(f) {
  content += `
              <option value="${f.idfournisseur}">${f.raisonsocial}</option>`;
});

const matieresOptionsForJs = matieres.map(function(m) {
  return `<option value="${m.idmp}">${m.libellé}</option>`;
}).join('');

content += `
            </select>
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
              <i class="fas fa-chevron-down text-slate-400"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Lines Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="p-6 border-b border-slate-200 flex justify-between items-center">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
            <i class="fas fa-list text-emerald-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-800">Lignes de commande</h3>
            <p class="text-sm text-slate-500">Ajoutez les matières premières à commander</p>
          </div>
        </div>
      </div>
      
      <div class="p-6">
        <div id="lignes" class="space-y-4">
          <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Matière première</label>
                <select name="lignes[0][idmp]" required 
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white">
                  <option value="">Sélectionner</option>`;

matieres.forEach(function(m) {
  content += `
                  <option value="${m.idmp}">${m.libellé}</option>`;
});

content += `
                </select>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Quantité</label>
                <input type="number" name="lignes[0][qtecommande]" placeholder="Qté" required 
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
              </div>
              
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Prix unitaire</label>
                <input type="number" step="0.01" name="lignes[0][prixunitaire]" placeholder="Prix" required 
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">
              </div>
            </div>
          </div>
        </div>
        
        <button type="button" id="ajouterLigneBtn" 
          class="mt-4 inline-flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-lg transition-all duration-200">
          <i class="fas fa-plus"></i>
          <span>Ajouter une ligne</span>
        </button>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex justify-end space-x-4">
      <a href="/commandes" class="inline-flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-3 rounded-xl transition-all duration-200">
        <i class="fas fa-times"></i>
        <span>Annuler</span>
      </a>
      <button type="submit" 
        class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-semibold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
        <i class="fas fa-check"></i>
        <span>Créer la commande</span>
      </button>
    </div>
  </form>
</div>

<script>
var matieresOptions = ${JSON.stringify(matieresOptionsForJs)};

document.getElementById('ajouterLigneBtn').onclick = function() {
  const container = document.getElementById('lignes');
  const index = container.children.length;
  const div = document.createElement('div');
  div.className = 'bg-slate-50 rounded-xl p-4 border border-slate-200';
  
  div.innerHTML = 
    '<div class="grid grid-cols-1 md:grid-cols-3 gap-4">' +
      '<div>' +
        '<label class="block text-sm font-medium text-slate-700 mb-2">Matière première</label>' +
        '<select name="lignes[' + index + '][idmp]" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white">' +
          '<option value="">Sélectionner</option>' +
          matieresOptions +
        '</select>' +
      '</div>' +
      '<div>' +
        '<label class="block text-sm font-medium text-slate-700 mb-2">Quantité</label>' +
        '<input type="number" name="lignes[' + index + '][qtecommande]" placeholder="Qté" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">' +
      '</div>' +
      '<div>' +
        '<label class="block text-sm font-medium text-slate-700 mb-2">Prix unitaire</label>' +
        '<input type="number" step="0.01" name="lignes[' + index + '][prixunitaire]" placeholder="Prix" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200">' +
      '</div>' +
    '</div>';
  container.appendChild(div);
};
</script>
`;
%>
<%- include('../layout', { body: content }) %>
