<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Nouvelle Réception</h1>
    <p class="text-gray-600 mt-1">Enregistrer l'arrivée physique des marchandises en entrepôt</p>
  </div>

  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <form method="POST" action="/magasinier/reception" class="space-y-6" id="reception-form">
        <!-- Commande & fournisseur -->
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Livraison</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="idcommande" class="block text-sm font-medium text-gray-700 mb-2">Commande liée</label>
              <select name="idcommande" id="idcommande"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">Aucune commande</option>
                <% commandes.forEach(function(c) { %>
                  <option value="<%= c.idcommande %>" data-fournisseur="<%= c.idfournisseur || '' %>">
                    n°<%= c.idcommande %> — <%= c.reference || 'Sans réf.' %> (<%= c.fournisseur_nom || 'Fournisseur N/A' %>) — <%= c.statut %>
                  </option>
                <% }); %>
              </select>
            </div>
            <div>
              <label for="idfournisseur" class="block text-sm font-medium text-gray-700 mb-2">Fournisseur</label>
              <select name="idfournisseur" id="idfournisseur"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">— Sélectionner —</option>
                <% fournisseurs.forEach(function(f) { %>
                  <option value="<%= f.idfournisseur %>"><%= f.raisonsocial %></option>
                <% }); %>
              </select>
              <p class="text-xs text-gray-500 mt-1">Rempli automatiquement si une commande est sélectionnée</p>
            </div>
            <div>
              <label for="bon_livraison" class="block text-sm font-medium text-gray-700 mb-2">Bon de livraison</label>
              <input type="text" name="bon_livraison" id="bon_livraison"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="N° BL">
            </div>
            <div>
              <label for="date_reception" class="block text-sm font-medium text-gray-700 mb-2">Date de réception</label>
              <input type="date" name="date_reception" id="date_reception"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="md:col-span-2">
              <label for="chauffeur" class="block text-sm font-medium text-gray-700 mb-2">Chauffeur / transport</label>
              <input type="text" name="chauffeur" id="chauffeur"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Nom ou société de transport">
            </div>
          </div>
          <div id="commande-lignes-info" class="hidden mt-4 p-4 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-900"></div>
        </div>

        <!-- Produit reçu -->
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Produit reçu</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label for="idmp" class="block text-sm font-medium text-gray-700 mb-2">Matière première *</label>
              <select name="idmp" id="idmp" required
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">Sélectionner une matière</option>
                <% matieres.forEach(function(m) { %>
                  <option value="<%= m.idmp %>" data-codebarre="<%= m.codebarre || '' %>">
                    <%= m.libellé %><% if (m.codebarre) { %> (<%= m.codebarre %>)<% } %>
                  </option>
                <% }); %>
              </select>
            </div>
            <div>
              <label for="qtereçu" class="block text-sm font-medium text-gray-700 mb-2">Quantité reçue *</label>
              <input type="number" name="qtereçu" id="qtereçu" required min="1" step="1"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Ex: 100">
            </div>

            <div>
              <label for="lotnumero" class="block text-sm font-medium text-gray-700 mb-2">N° de lot</label>
              <input type="text" name="lotnumero" id="lotnumero"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="LOT-2026-001">
            </div>
          </div>
        </div>

        <!-- Contrôle qualité -->
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Contrôle qualité</h3>
          <div class="space-y-4">
            <div class="flex flex-wrap gap-4">
              <label class="flex items-center">
                <input type="radio" name="quality_status" value="conforme" checked class="mr-2">
                <span class="text-sm text-gray-700">Conforme</span>
              </label>
              <label class="flex items-center">
                <input type="radio" name="quality_status" value="non_conforme" class="mr-2">
                <span class="text-sm text-gray-700">Non conforme</span>
              </label>
              <label class="flex items-center">
                <input type="radio" name="quality_status" value="partiel" class="mr-2">
                <span class="text-sm text-gray-700">Partiellement conforme</span>
              </label>
            </div>
            <div>
              <label for="observations" class="block text-sm font-medium text-gray-700 mb-2">Observations</label>
              <textarea name="observations" id="observations" rows="3"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Écarts, casse, remarques…"></textarea>
            </div>
          </div>
        </div>

        <!-- Entrepôt -->
        <div>
          <h3 class="text-lg font-medium text-gray-900 mb-4">Emplacement</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="identret" class="block text-sm font-medium text-gray-700 mb-2">Entrepôt *</label>
              <select name="identret" id="identret" required
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">Sélectionner un entrepôt</option>
                <% entrepots.forEach(function(e, idx) { %>
                  <option value="<%= e.identret %>" <%= idx === 0 ? 'selected' : '' %>><%= e.nom %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label for="zone" class="block text-sm font-medium text-gray-700 mb-2">Zone / emplacement</label>
              <input type="text" name="zone" id="zone"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                placeholder="Ex: A-12">
            </div>
          </div>
        </div>

        <div class="flex justify-between items-center pt-6 border-t border-gray-200">
          <a href="/magasinier/dashboard" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
            <i class="fas fa-arrow-left mr-2"></i>Retour
          </a>
          <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-semibold">
            <i class="fas fa-save mr-2"></i>Enregistrer la réception
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  const commandeSelect = document.getElementById('idcommande');
  const fournisseurSelect = document.getElementById('idfournisseur');
  const matiereSelect = document.getElementById('idmp');
  const qteInput = document.getElementById('qtereçu');
  const lignesInfo = document.getElementById('commande-lignes-info');
  const dateReception = document.getElementById('date_reception');

  if (dateReception) {
    dateReception.value = new Date().toISOString().split('T')[0];
  }

  let currentLignes = [];

  commandeSelect?.addEventListener('change', async function() {
    const id = this.value;
    const opt = this.options[this.selectedIndex];
    const idFournisseur = opt?.dataset?.fournisseur;

    if (idFournisseur && fournisseurSelect) {
      fournisseurSelect.value = idFournisseur;
      fournisseurSelect.disabled = true; // No longer selectable
    } else if (fournisseurSelect) {
      fournisseurSelect.disabled = false; // Selectable again
      fournisseurSelect.value = "";
    }

    if (!id) {
      currentLignes = [];
      lignesInfo.classList.add('hidden');
      lignesInfo.innerHTML = '';
      restoreAllMatieres();
      qteInput.value = "";
      qteInput.readOnly = false;
      return;
    }

    try {
      const res = await fetch('/magasinier/commande/' + id + '/lignes');
      const data = await res.json();
      if (!data.success) {
        lignesInfo.classList.remove('hidden');
        lignesInfo.innerHTML = '<p class="text-red-700">' + (data.error || 'Erreur') + '</p>';
        return;
      }

      currentLignes = data.lignes || [];
      let html = '<p class="font-semibold mb-2">Articles de la commande n°' + data.commande.idcommande + ' :</p><ul class="list-disc list-inside space-y-1">';
      const idsMp = [];
      currentLignes.forEach(function(l) {
        const reste = Math.max(0, Number(l.qtecommande) - Number(l.qtelivrée || l.qtelivree || 0));
        html += '<li><strong>' + (l.libelle || 'Matière') + '</strong> — commandé: ' + l.qtecommande + ', déjà reçu: ' + (l.qtelivrée || l.qtelivree || 0) + ', reste: ' + reste + '</li>';
        idsMp.push(String(l.idmp));
      });
      html += '</ul>';
      lignesInfo.innerHTML = html;
      lignesInfo.classList.remove('hidden');

      filterMatieres(idsMp);
      
      // Auto-prefill if there is only 1 line
      if (currentLignes.length === 1) {
        matiereSelect.value = String(currentLignes[0].idmp);
        const reste = Math.max(0, Number(currentLignes[0].qtecommande) - Number(currentLignes[0].qtelivrée || currentLignes[0].qtelivree || 0));
        qteInput.value = reste;
        qteInput.readOnly = true; // Lock it!
      } else {
        matiereSelect.value = "";
        qteInput.value = "";
        qteInput.readOnly = true; // Locked until a material is chosen
      }
    } catch (e) {
      console.error(e);
    }
  });

  matiereSelect?.addEventListener('change', function() {
    const selectedMpId = this.value;
    if (!selectedMpId) {
      if (commandeSelect.value) {
        qteInput.value = "";
        qteInput.readOnly = true;
      } else {
        qteInput.readOnly = false;
      }
      return;
    }

    if (commandeSelect.value) {
      const line = currentLignes.find(l => String(l.idmp) === String(selectedMpId));
      if (line) {
        const reste = Math.max(0, Number(line.qtecommande) - Number(line.qtelivrée || line.qtelivree || 0));
        qteInput.value = reste;
        qteInput.readOnly = true;
      } else {
        qteInput.value = "";
        qteInput.readOnly = true;
      }
    } else {
      qteInput.readOnly = false;
    }
  });

  // Re-enable disabled elements on submit so they get processed by the backend
  document.getElementById('reception-form')?.addEventListener('submit', function() {
    if (fournisseurSelect) fournisseurSelect.disabled = false;
  });

  const allMatiereOptions = matiereSelect ? Array.from(matiereSelect.options).map(function(o) {
    return { value: o.value, text: o.text, codebarre: o.dataset.codebarre || '' };
  }) : [];

  function restoreAllMatieres() {
    if (!matiereSelect) return;
    matiereSelect.innerHTML = '<option value="">Sélectionner une matière</option>';
    allMatiereOptions.forEach(function(o) {
      if (!o.value) return;
      const opt = document.createElement('option');
      opt.value = o.value;
      opt.textContent = o.text;
      opt.dataset.codebarre = o.codebarre;
      matiereSelect.appendChild(opt);
    });
  }

  function filterMatieres(idsMp) {
    if (!matiereSelect) return;
    matiereSelect.innerHTML = '<option value="">Sélectionner une matière</option>';
    allMatiereOptions.forEach(function(o) {
      if (o.value && idsMp.includes(o.value)) {
        const opt = document.createElement('option');
        opt.value = o.value;
        opt.textContent = o.text;
        opt.dataset.codebarre = o.codebarre;
        matiereSelect.appendChild(opt);
      }
    });
  }


})();
</script>
