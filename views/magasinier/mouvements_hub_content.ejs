<div class="space-y-8">
  <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">Flux matière première</p>
      <h1 class="text-3xl font-bold text-gray-900 mt-1">Mouvements de stock</h1>
      <p class="text-gray-600 mt-2 max-w-2xl">
        Pilotez le cycle <strong class="text-gray-800">réception → stock → production</strong>. Les sorties vers production mettent à jour les quantités réelles pour que les <strong>alertes seuils</strong> restent pertinentes.
      </p>
    </div>
    <a href="/magasinier/dashboard" class="inline-flex items-center px-4 py-2 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-50 text-sm font-medium shrink-0">
      <i class="fas fa-arrow-left mr-2"></i> Tableau de bord
    </a>
  </div>

  <% var ct = countsToday || {}; %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-700 text-white p-5 shadow-lg">
      <p class="text-emerald-100 text-xs font-semibold uppercase">Entrées aujourd’hui</p>
      <p class="text-3xl font-bold mt-2"><%= ct.entree || 0 %></p>
      <p class="text-emerald-100 text-xs mt-1">Réceptions & entrées stock</p>
    </div>
    <div class="rounded-2xl bg-gradient-to-br from-rose-500 to-red-700 text-white p-5 shadow-lg">
      <p class="text-rose-100 text-xs font-semibold uppercase">Sorties aujourd’hui</p>
      <p class="text-3xl font-bold mt-2"><%= ct.sortie || 0 %></p>
      <p class="text-rose-100 text-xs mt-1">Dont production</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <a href="/magasinier/reception" class="group rounded-2xl border-2 border-blue-100 bg-white p-6 shadow-sm hover:shadow-xl hover:border-blue-300 transition-all">
      <div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-700 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
        <i class="fas fa-truck-loading text-xl"></i>
      </div>
      <h3 class="text-lg font-bold text-gray-900">Réception</h3>
      <p class="text-sm text-gray-600 mt-2">Entrée marchandise (livraison fournisseur).</p>
      <span class="inline-flex items-center mt-4 text-sm font-semibold text-blue-700">Accéder <i class="fas fa-chevron-right ml-2 text-xs"></i></span>
    </a>

    <a href="/magasinier/mouvements/sortie-production" class="group rounded-2xl border-2 border-rose-100 bg-white p-6 shadow-sm hover:shadow-xl hover:border-rose-300 transition-all">
      <div class="w-12 h-12 rounded-xl bg-rose-100 text-rose-700 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
        <i class="fas fa-industry text-xl"></i>
      </div>
      <h3 class="text-lg font-bold text-gray-900">Sortie production</h3>
      <p class="text-sm text-gray-600 mt-2">Consommation MP vers atelier / ligne (réf. OF).</p>
      <span class="inline-flex items-center mt-4 text-sm font-semibold text-rose-700">Enregistrer <i class="fas fa-chevron-right ml-2 text-xs"></i></span>
    </a>
  </div>

  <div class="bg-white rounded-2xl shadow border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between bg-gray-50/80">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-gray-900 text-white flex items-center justify-center">
          <i class="fas fa-stream"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900">Flux récent</h3>
          <p class="text-xs text-gray-500">Derniers mouvements enregistrés (tous types)</p>
        </div>
      </div>
    </div>
    <div class="divide-y divide-gray-100">
      <% if (typeof recentFlow !== 'undefined' && recentFlow.length > 0) { %>
        <% recentFlow.forEach(function(m) {
          var sdRaw = m.stock_delta;
          var delta = (sdRaw !== null && sdRaw !== undefined && sdRaw !== '') ? Number(sdRaw) : (m.type_mouvement === 'entree' ? Number(m.quantite) : -Number(m.quantite));
          var isPlus = delta >= 0;
          var badgeBg = isPlus ? 'bg-emerald-50 text-emerald-800 border-emerald-200' : 'bg-rose-50 text-rose-800 border-rose-200';
          var typeLabel = ({ entree: 'Entrée', sortie: 'Sortie', transfert: 'Transfert', ajustement: 'Ajustement' })[m.type_mouvement] || m.type_mouvement;
        %>
          <div class="px-6 py-4 flex flex-wrap items-start gap-4 hover:bg-gray-50/60 transition-colors">
            <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold border <%= badgeBg %>"><%= typeLabel %></span>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-900">
                <%= isPlus ? '+' : '' %><%= delta %> Kg · <%= m.matiere %>
              </p>
              <p class="text-sm text-gray-600 truncate"><%= m.motif || '—' %></p>
              <p class="text-xs text-gray-400 mt-1"><%= m.entrepot_nom %> <% if (m.idcommande) { %> · Cmd n°<%= m.idcommande %><% } %></p>
            </div>
            <div class="text-right text-xs text-gray-400 whitespace-nowrap">
              <%= m.date_mouvement ? new Date(m.date_mouvement).toLocaleString('fr-FR') : '' %>
              <% var ulab = (m.user_prenom || '') + ' ' + (m.user_nom || ''); ulab = ulab.trim(); %>
              <% if (ulab) { %><div class="mt-1 text-gray-500"><%= ulab %></div><% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="px-6 py-12 text-center text-gray-500 text-sm">Aucun mouvement récent.</div>
      <% } %>
    </div>
  </div>
</div>
