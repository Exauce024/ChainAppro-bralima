<div class="max-w-3xl mx-auto space-y-8">
  <div>
    <a href="/magasinier/mouvements" class="text-sm font-medium text-blue-700 hover:text-blue-900 inline-flex items-center mb-4">
      <i class="fas fa-arrow-left mr-2"></i> Retour aux mouvements
    </a>
    <h1 class="text-3xl font-bold text-gray-900">Transfert entre entrepôts</h1>
    <p class="text-gray-600 mt-2">Déplacez une quantité de la <strong>même matière première</strong> vers un autre entrepôt. Une ligne de stock destination sera créée si nécessaire.</p>
  </div>

  <form method="POST" action="/magasinier/mouvements/transfert" class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-indigo-600 to-blue-800 px-6 py-5 text-white">
      <h2 class="text-lg font-semibold flex items-center gap-2">
        <i class="fas fa-random"></i> Ordre de transfert interne
      </h2>
      <p class="text-indigo-100 text-sm mt-1">Référence bon interne ou véhicule obligatoire.</p>
    </div>
    <div class="p-6 space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Stock source</label>
        <select name="idstock_source" required id="srcStock"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <option value="">— Sélectionner —</option>
          <% (lignesStock || []).forEach(function(l) { %>
            <option value="<%= l.idstock %>" data-identret="<%= l.identret %>">
              <%= l.libelle %> · <%= l.entrepot_nom %> · Lot: <%= l.lotnumero || 'N/A' %> <% if (l.dateperemption) { %>(Périm: <%= new Date(l.dateperemption).toLocaleDateString('fr-FR') %>)<% } %> · <%= Number(l.qtedisponible || 0).toLocaleString('fr-FR') %> u.
            </option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Entrepôt destination</label>
        <select name="identret_dest" required id="destEntrepot"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
          <option value="">— Sélectionner —</option>
          <% (entrepots || []).forEach(function(e) { %>
            <option value="<%= e.identret %>"><%= e.nom %></option>
          <% }); %>
        </select>
        <p class="text-xs text-gray-500 mt-2">Doit être différent de l’entrepôt source.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Quantité</label>
          <input type="number" name="quantite" min="1" step="1" required
                 class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Référence <span class="text-red-500">*</span></label>
          <input type="text" name="reference" required placeholder="Bon INT-… / véhicule…"
                 class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
        </div>
      </div>
      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="inline-flex items-center px-6 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-blue-700 text-white font-semibold shadow hover:opacity-95 transition-opacity">
          <i class="fas fa-check mr-2"></i> Exécuter le transfert
        </button>
        <a href="/magasinier/mouvements" class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-300 text-gray-700 font-medium hover:bg-gray-50">Annuler</a>
      </div>
    </div>
  </form>
</div>
