    <a href="/magasinier/scan" class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-2xl p-6 text-white shadow-lg hover:shadow-xl transition-all duration-300 flex items-center space-x-4">
      <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center">
