<div class="max-w-3xl mx-auto space-y-8">
  <div>
    <a href="/magasinier/mouvements" class="text-sm font-medium text-blue-700 hover:text-blue-900 inline-flex items-center mb-4">
      <i class="fas fa-arrow-left mr-2"></i> Retour aux mouvements
    </a>
    <h1 class="text-3xl font-bold text-gray-900">Ajustement inventaire</h1>
    <p class="text-gray-600 mt-2">Corrigez les écarts après inventaire physique ou contrôle qualité. Un motif détaillé est obligatoire (audit).</p>
  </div>

  <form method="POST" action="/magasinier/mouvements/ajustement" class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-amber-500 to-orange-600 px-6 py-5 text-white">
      <h2 class="text-lg font-semibold flex items-center gap-2">
        <i class="fas fa-balance-scale"></i> Fiche d’ajustement
      </h2>
      <p class="text-amber-100 text-sm mt-1">Gain (+) ou perte (−) sur une ligne de stock existante.</p>
    </div>
    <div class="p-6 space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Ligne de stock</label>
        <select name="idstock" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-amber-500 focus:border-amber-500">
          <option value="">— Sélectionner —</option>
          <% (lignesStock || []).forEach(function(l) { %>
            <option value="<%= l.idstock %>">
              <%= l.libelle %> · <%= l.entrepot_nom %> · Lot: <%= l.lotnumero || 'N/A' %> <% if (l.dateperemption) { %>(Périm: <%= new Date(l.dateperemption).toLocaleDateString('fr-FR') %>)<% } %> · <%= Number(l.qtedisponible || 0).toLocaleString('fr-FR') %> u.
            </option>
          <% }); %>
        </select>
      </div>
      <div>
        <span class="block text-sm font-medium text-gray-700 mb-3">Sens</span>
        <div class="flex flex-wrap gap-4">
          <label class="inline-flex items-center gap-2 px-4 py-3 rounded-xl border-2 border-emerald-200 bg-emerald-50 cursor-pointer has-[:checked]:border-emerald-500">
            <input type="radio" name="sens" value="plus" required class="text-emerald-600">
            <span class="font-medium text-emerald-900">Gain (+)</span>
          </label>
          <label class="inline-flex items-center gap-2 px-4 py-3 rounded-xl border-2 border-rose-200 bg-rose-50 cursor-pointer has-[:checked]:border-rose-500">
            <input type="radio" name="sens" value="moins" class="text-rose-600">
            <span class="font-medium text-rose-900">Perte (−)</span>
          </label>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Quantité (unités)</label>
        <input type="number" name="quantite" min="1" step="1" required
               class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-amber-500 focus:border-amber-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Motif / justification <span class="text-red-500">*</span> <span class="text-gray-400 font-normal">(min. 10 caractères)</span></label>
        <textarea name="motif" rows="3" required minlength="10" placeholder="Ex. Écart inventaire annuel zone B — constat physique vs système…"
                  class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-amber-500 focus:border-amber-500"></textarea>
      </div>
      <div class="flex flex-wrap gap-3 pt-2">
        <button type="submit" class="inline-flex items-center px-6 py-3 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 text-white font-semibold shadow hover:opacity-95 transition-opacity">
          <i class="fas fa-check mr-2"></i> Enregistrer l’ajustement
        </button>
        <a href="/magasinier/mouvements" class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-300 text-gray-700 font-medium hover:bg-gray-50">Annuler</a>
      </div>
    </div>
  </form>
</div>
