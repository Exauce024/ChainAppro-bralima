<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Mode Scan Mobile</h1>
    <p class="text-gray-600 mt-1">Scanner les codes-barres pour la gestion de stock</p>
  </div>

  <!-- Scan Interface -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <!-- Camera View -->
      <div class="mb-6">
        <div class="relative bg-black rounded-lg overflow-hidden" style="height: 400px;">
          <video id="camera-video" class="w-full h-full object-cover"></video>
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2">
              <div class="w-64 h-64 border-2 border-green-400 rounded-lg">
                <div class="absolute top-0 left-0 w-8 h-8 border-t-4 border-l-4 border-green-400"></div>
                <div class="absolute top-0 right-0 w-8 h-8 border-t-4 border-r-4 border-green-400"></div>
                <div class="absolute bottom-0 left-0 w-8 h-8 border-b-4 border-l-4 border-green-400"></div>
                <div class="absolute bottom-0 right-0 w-8 h-8 border-b-4 border-r-4 border-green-400"></div>
              </div>
            </div>
          </div>
          <div class="absolute top-4 left-4">
            <button onclick="toggleCamera()" class="bg-white/90 text-gray-800 p-2 rounded-lg hover:bg-white">
              <i class="fas fa-camera"></i>
            </button>
          </div>
          <div class="absolute top-4 right-4">
            <button onclick="toggleFlash()" class="bg-white/90 text-gray-800 p-2 rounded-lg hover:bg-white">
              <i class="fas fa-bolt"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Scan Controls -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <button onclick="startScanning()" class="bg-green-600 text-white px-4 py-3 rounded-lg hover:bg-green-700">
          <i class="fas fa-play mr-2"></i>Commencer le scan
        </button>
        <button onclick="stopScanning()" class="bg-red-600 text-white px-4 py-3 rounded-lg hover:bg-red-700">
          <i class="fas fa-stop mr-2"></i>Arrêter le scan
        </button>
        <button onclick="manualInput()" class="bg-blue-600 text-white px-4 py-3 rounded-lg hover:bg-blue-700">
          <i class="fas fa-keyboard mr-2"></i>Saisie manuelle
        </button>
      </div>

      <!-- Manual Input Modal (Hidden by default) -->
      <div id="manual-input-modal" class="hidden mb-6 p-4 bg-gray-50 rounded-lg">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Saisie manuelle du code-barres</h3>
        <div class="flex space-x-4">
          <input type="text" id="manual-barcode" placeholder="Entrez le code-barres" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
          <button onclick="processManualInput()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            Valider
          </button>
          <button onclick="closeManualInput()" class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700">
            Annuler
          </button>
        </div>
      </div>

      <!-- Recent Scans -->
      <div>
        <h3 class="text-lg font-medium text-gray-900 mb-4">Scans récents</h3>
        <div id="scans-list" class="space-y-2">
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                <i class="fas fa-check text-green-600 text-xs"></i>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">PROD001 - Carte SIM Standard</p>
                <p class="text-xs text-gray-500">Scanné il y a 2 minutes</p>
              </div>
            </div>
            <span class="text-xs text-gray-400">12:34:56</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Statistics -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Scans aujourd'hui</p>
          <p class="text-2xl font-bold text-gray-900">47</p>
        </div>
        <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-barcode text-blue-600"></i>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Produits traités</p>
          <p class="text-2xl font-bold text-gray-900">23</p>
        </div>
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-box text-green-600"></i>
        </div>
      </div>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-500">Erreurs</p>
          <p class="text-2xl font-bold text-gray-900">2</p>
        </div>
        <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-exclamation-triangle text-red-600"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
let isScanning = false;
let scanCount = 0;
let errorCount = 0;
let stream = null;

// Simulated product database
const products = {
  'PROD001': { name: 'Carte SIM Standard', location: 'A-12', stock: 150 },
  'PROD002': { name: 'Carte SIM Data', location: 'B-05', stock: 89 },
  'PROD003': { name: 'Rechargeur USB', location: 'C-08', stock: 45 },
  'PROD004': { name: 'Câble USB-C', location: 'D-11', stock: 200 },
  'PROD005': { name: 'Coque téléphone', location: 'E-03', stock: 78 }
};

function startScanning() {
  if (isScanning) return;
  
  isScanning = true;
  scanCount = 0;
  
  // Simulate camera activation
  showNotification('Camera activée', 'success');
  
  // Simulate continuous scanning
  const scanInterval = setInterval(() => {
    if (!isScanning) {
      clearInterval(scanInterval);
      return;
    }
    
    // Simulate random barcode scan
    const codes = Object.keys(products);
    const randomCode = codes[Math.floor(Math.random() * codes.length)];
    processScan(randomCode);
  }, 3000);
}

function stopScanning() {
  isScanning = false;
  showNotification('Scan arrêté', 'info');
}

function toggleCamera() {
  // Simulate camera toggle
  const video = document.getElementById('camera-video');
  if (stream) {
    stream.getTracks().forEach(track => track.stop());
    stream = null;
    video.style.display = 'none';
    showNotification('Camera désactivée', 'info');
  } else {
    // In real app, would access camera
    video.style.display = 'block';
    showNotification('Camera activée', 'success');
  }
}

function toggleFlash() {
  showNotification('Flash basculé', 'info');
}

function manualInput() {
  document.getElementById('manual-input-modal').classList.remove('hidden');
  document.getElementById('manual-barcode').focus();
}

function closeManualInput() {
  document.getElementById('manual-input-modal').classList.add('hidden');
  document.getElementById('manual-barcode').value = '';
}

function processManualInput() {
  const barcode = document.getElementById('manual-barcode').value.trim();
  if (barcode) {
    processScan(barcode);
    closeManualInput();
  }
}

function processScan(barcode) {
  const product = products[barcode];
  const timestamp = new Date().toLocaleTimeString('fr-FR');
  
  if (product) {
    scanCount++;
    addScanToList({
      barcode: barcode,
      name: product.name,
      location: product.location,
      timestamp: timestamp,
      status: 'success'
    });
    showNotification(`Produit scanné: ${product.name}`, 'success');
  } else {
    errorCount++;
    addScanToList({
      barcode: barcode,
      name: 'Produit inconnu',
      location: '---',
      timestamp: timestamp,
      status: 'error'
    });
    showNotification('Code-barres non reconnu', 'error');
  }
  
  updateStatistics();
}

function addScanToList(scan) {
  const scansList = document.getElementById('scans-list');
  const scanItem = document.createElement('div');
  
  const bgColor = scan.status === 'success' ? 'bg-green-50' : 'bg-red-50';
  const iconColor = scan.status === 'success' ? 'text-green-600' : 'text-red-600';
  const icon = scan.status === 'success' ? 'fa-check' : 'fa-times';
  
  scanItem.className = `flex items-center justify-between p-3 ${bgColor} rounded-lg`;
  scanItem.innerHTML = `
    <div class="flex items-center space-x-3">
      <div class="w-8 h-8 ${scan.status === 'success' ? 'bg-green-100' : 'bg-red-100'} rounded-full flex items-center justify-center">
        <i class="fas ${icon} ${iconColor} text-xs"></i>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900">${scan.barcode} - ${scan.name}</p>
        <p class="text-xs text-gray-500">Emplacement: ${scan.location}</p>
      </div>
    </div>
    <span class="text-xs text-gray-400">${scan.timestamp}</span>
  `;
  
  scansList.insertBefore(scanItem, scansList.firstChild);
  
  // Keep only last 10 scans
  while (scansList.children.length > 10) {
    scansList.removeChild(scansList.lastChild);
  }
}

function updateStatistics() {
  // Update scan count
  const scanElement = document.querySelector('.text-2xl');
  if (scanElement) {
    scanElement.textContent = scanCount;
  }
  
  // Update error count
  const errorElements = document.querySelectorAll('.text-2xl');
  if (errorElements.length >= 3) {
    errorElements[2].textContent = errorCount;
  }
}

function showNotification(message, type) {
  const notification = document.createElement('div');
  const bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : 'bg-blue-500';
  
  notification.className = `fixed top-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg z-50`;
  notification.textContent = message;
  
  document.body.appendChild(notification);
  
  setTimeout(() => {
    if (notification.parentNode) {
      notification.parentNode.removeChild(notification);
    }
  }, 3000);
}

// Keyboard support for manual input
document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('manual-barcode').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      processManualInput();
    }
  });
});
</script>
