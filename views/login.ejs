<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion – BRALIMA Supply Chain</title>
  <link rel="icon" type="image/png" href="/images/bralima-logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }

  </style>
</head>
<body class="bg-gradient-to-br from-slate-100 to-blue-50 min-h-screen flex items-center justify-center p-4">

  <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row overflow-hidden w-full max-w-3xl">

    <!-- LEFT – Blue Panel with Logo -->
    <div class="w-full md:w-1/2 bg-gradient-to-br from-blue-700 via-blue-800 to-indigo-950 text-white p-8 flex flex-col justify-center items-center relative overflow-hidden rounded-t-3xl md:rounded-t-none md:rounded-l-3xl">


      <!-- Circle glow effects -->
      <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full pointer-events-none" style="background:rgba(59,130,246,0.2);filter:blur(40px)"></div>
      <div class="absolute -top-16 -left-16 w-72 h-72 rounded-full pointer-events-none" style="background:rgba(99,102,241,0.2);filter:blur(50px)"></div>

      <!-- Logo circle -->
      <div class="relative z-10 w-44 h-44 rounded-full flex items-center justify-center shadow-2xl" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2)">
        <div class="w-36 h-36 bg-white rounded-full flex items-center justify-center shadow-inner p-2">
          <img src="/images/bralima-logo.png" alt="BRALIMA Logo" class="w-28 h-28 object-contain rounded-xl">
        </div>
      </div>

      <!-- Brand name -->
      <div class="mt-6 text-center z-10">
        <h2 class="text-2xl font-extrabold tracking-widest uppercase">BRALIMA</h2>
        <p class="text-xs mt-1 uppercase tracking-widest font-medium" style="color:rgba(191,219,254,0.8)">Supply Chain Management</p>
      </div>
    </div>

    <!-- RIGHT – Login Form -->
    <div class="w-full md:w-1/2 bg-white p-8 md:p-10 flex flex-col justify-center">

      <!-- Header -->
      <div class="mb-6">
        <h1 class="text-xl md:text-2xl font-extrabold text-gray-800 leading-snug">Bienvenu sur la plateforme Supply Chain</h1>
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mt-2">Connexion</p>
      </div>

      <!-- Alert messages -->
      <% if (error) { %>
        <div class="mb-5 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm flex items-center gap-3">
          <i class="fas fa-exclamation-circle text-red-400 text-base flex-shrink-0"></i>
          <span><%= error %></span>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="mb-5 p-4 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl text-sm flex items-center gap-3">
          <i class="fas fa-check-circle text-emerald-400 text-base flex-shrink-0"></i>
          <span><%= success %></span>
        </div>
      <% } %>

      <!-- Form -->
      <form method="POST" action="/login" class="space-y-6">

        <!-- Email -->
        <div class="relative">
          <label for="email" class="absolute px-1.5 bg-white text-xs font-semibold text-gray-500 z-10" style="top:-10px;left:14px">
            Email<span class="text-red-500">*</span>
          </label>
          <div class="border border-gray-300 rounded-xl px-4 py-3.5 flex items-center justify-between focus-within:ring-2 focus-within:ring-blue-600 focus-within:border-transparent bg-gray-50 hover:bg-white transition-all duration-200">
            <input type="email" name="email" id="email" required
              class="w-full bg-transparent border-none outline-none p-0 text-sm text-gray-800 placeholder-gray-400"
              placeholder="ex: utilisateur@bralima.cd">
            <i class="fas fa-user text-gray-400 ml-2 flex-shrink-0"></i>
          </div>
        </div>

        <!-- Password -->
        <div class="relative">
          <label for="motdepasse" class="absolute px-1.5 bg-white text-xs font-semibold text-gray-500 z-10" style="top:-10px;left:14px">
            Mot de passe <span class="text-red-500">*</span>
          </label>
          <div class="border border-gray-300 rounded-xl px-4 py-3.5 flex items-center justify-between focus-within:ring-2 focus-within:ring-blue-600 focus-within:border-transparent bg-gray-50 hover:bg-white transition-all duration-200">
            <input type="password" name="motdepasse" id="motdepasse" required
              class="w-full bg-transparent border-none outline-none p-0 text-sm text-gray-800 placeholder-gray-400"
              placeholder="Mot de passe">
            <i class="fas fa-key text-gray-400 ml-2 flex-shrink-0"></i>
          </div>
        </div>

        <!-- Submit -->
        <button type="submit"
          class="w-full bg-blue-700 hover:bg-blue-800 text-white font-bold py-3.5 rounded-xl shadow-lg transform hover:-translate-y-0.5 transition-all duration-200 text-sm tracking-wide">
          Connexion
        </button>

      </form>

      <!-- Footer -->
      <div class="mt-6 pt-4 border-t border-gray-100 text-center">
        <span class="text-xs text-gray-400">&copy; 2026 BRALIMA – Système de gestion Supply Chain</span>
      </div>

    </div>
  </div>

</body>
</html>
