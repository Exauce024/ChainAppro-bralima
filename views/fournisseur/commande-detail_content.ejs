<div class="space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Détails de la Commande n°<%= commande.idcommande %></h1>
      <p class="text-gray-600 mt-1">Informations détaillées de la commande</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/fournisseur/commande/<%= commande.idcommande %>/bon-commande.pdf" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-900 transition-colors text-sm inline-flex items-center" target="_blank" rel="noopener noreferrer">
        <i class="fas fa-file-pdf mr-2"></i>Bon de commande
      </a>
      <% if (typeof bonTransportDisponible !== 'undefined' && bonTransportDisponible) { %>
        <a href="/fournisseur/commande/<%= commande.idcommande %>/bon-transport.pdf" class="px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors text-sm inline-flex items-center" target="_blank" rel="noopener noreferrer" title="À remettre au chauffeur — pour la livraison de la matière première.">
          <i class="fas fa-dolly mr-2"></i>Chauffeur / transport
        </a>
      <% } %>
      <% if (commande.statut === 'livree') { %>
        <a href="/fournisseur/commande/<%= commande.idcommande %>/bon-livraison.pdf" class="px-4 py-2 bg-emerald-700 text-white rounded-lg hover:bg-emerald-800 transition-colors text-sm inline-flex items-center" target="_blank" rel="noopener noreferrer">
          <i class="fas fa-clipboard-check mr-2"></i>Bon livraison (réception)
        </a>
      <% } %>
    </div>
  </div>

  <!-- Order Info Card -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b border-gray-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-info-circle text-blue-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Informations générales</h3>
          <p class="text-sm text-gray-500">Détails de la commande</p>
        </div>
      </div>
    </div>
    
    <div class="p-6 space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Fournisseur</p>
          <p class="text-lg font-semibold text-gray-900"><%= commande.raisonsocial || 'N/A' %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Date de création</p>
          <p class="text-lg font-semibold text-gray-900"><%= commande.datecreation ? new Date(commande.datecreation).toLocaleDateString('fr-FR') : 'N/A' %></p>
        </div>
      </div>
      
      <div>
        <p class="text-sm text-gray-500">Statut</p>
        <% 
        var badgeClass = 'bg-gray-100 text-gray-800';
        var statusLabel = commande.statut || 'N/A';
        if (commande.statut === 'approuvee') { 
          badgeClass = 'bg-emerald-100 text-emerald-800'; 
          statusLabel = 'Approuvée';
        } else if (commande.statut === 'refusee') { 
          badgeClass = 'bg-red-100 text-red-800'; 
          statusLabel = 'Refusée';
        } else if (commande.statut === 'envoyee') { 
          badgeClass = 'bg-blue-100 text-blue-800'; 
          statusLabel = 'Envoyée';
        } else if (commande.statut === 'en_cours_de_livraison') { 
          badgeClass = 'bg-amber-100 text-amber-800'; 
          statusLabel = 'En cours de livraison (Expédiée)';
        } else if (commande.statut === 'livree') { 
          badgeClass = 'bg-green-100 text-green-800'; 
          statusLabel = 'Livrée';
        }
        %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= badgeClass %>">
          <span class="w-2 h-2 rounded-full <%= commande.statut === 'approuvee' ? 'bg-emerald-500' : commande.statut === 'refusee' ? 'bg-red-500' : commande.statut === 'envoyee' ? 'bg-blue-500' : commande.statut === 'en_cours_de_livraison' ? 'bg-amber-500' : commande.statut === 'livree' ? 'bg-green-500' : 'bg-gray-500' %> mr-2"></span>
          <%= statusLabel %>
        </span>
      </div>
      
      <div>
        <p class="text-sm text-gray-500">Détails</p>
        <p class="text-gray-800 mt-1"><%= commande.details || 'Aucun détail disponible' %></p>
      </div>
      
      <div>
        <p class="text-sm text-gray-500">Montant total</p>
        <p class="text-2xl font-bold text-gray-900"><%= commande.montant ? formatMoney(commande.montant) : '—' %></p>
      </div>
    </div>
  </div>

  <!-- Order Items -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b border-gray-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-box text-purple-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Articles commandés</h3>
          <p class="text-sm text-gray-500">Détail des produits</p>
        </div>
      </div>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Matière première</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Quantité</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Prix unitaire</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if (typeof lignes !== 'undefined' && lignes.length > 0) { %>
            <% lignes.forEach(function(ligne) { 
              var totalLigne = Number(ligne.qtecommande) * Number(ligne.prixunitaire);
            %>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= ligne.libelle %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= ligne.qtecommande %> Kg</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= formatMoney(ligne.prixunitaire) %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= formatMoney(totalLigne) %></td>
              </tr>
            <% }); %>
            <tr class="bg-gray-50">
              <td colspan="3" class="px-6 py-4 text-right text-sm font-semibold text-gray-700">Total commande</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900"><%= formatMoney(commande.montant || 0) %></td>
            </tr>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">Aucun article enregistré pour cette commande.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Timeline -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6 border-b border-gray-200">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
          <i class="fas fa-history text-green-600"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Historique</h3>
          <p class="text-sm text-gray-500">Suivi de la commande</p>
        </div>
      </div>
    </div>
    
    <div class="p-6">
      <div class="space-y-4">
        <div class="flex items-start space-x-3">
          <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
            <i class="fas fa-paper-plane text-blue-600 text-xs"></i>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900">Commande envoyée</p>
            <p class="text-xs text-gray-500"><%= commande.datecreation ? new Date(commande.datecreation).toLocaleString('fr-FR') : '---' %></p>
          </div>
        </div>
        
        <% if (commande.statut === 'approuvee' || commande.statut === 'livree') { %>
          <div class="flex items-start space-x-3">
            <div class="w-8 h-8 bg-emerald-100 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-check text-emerald-600 text-xs"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900">Commande approuvée</p>
              <p class="text-xs text-gray-500">En attente de livraison</p>
            </div>
          </div>
        <% } %>
        
        <% if (commande.statut === 'en_cours_de_livraison' || commande.statut === 'livree') { %>
          <div class="flex items-start space-x-3">
            <div class="w-8 h-8 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-truck text-amber-600 text-xs"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900">En cours de livraison</p>
              <p class="text-xs text-gray-500">Expédié par le fournisseur</p>
            </div>
          </div>
        <% } %>
        
        <% if (commande.statut === 'livree') { %>
          <div class="flex items-start space-x-3">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-clipboard-check text-green-600 text-xs"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900">Commande livrée et réceptionnée</p>
              <p class="text-xs text-gray-500">Réceptionnée à l'entrepôt</p>
            </div>
          </div>
        <% } %>
        
        <% if (commande.statut === 'refusee') { %>
          <div class="flex items-start space-x-3">
            <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
              <i class="fas fa-times text-red-600 text-xs"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900">Commande refusée</p>
              <p class="text-xs text-gray-500">La commande a été refusée</p>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (['envoyee', 'en_attente'].includes(commande.statut)) { %>
    <!-- Response Form Card -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-6 border-b border-gray-200">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center">
            <i class="fas fa-reply text-emerald-600"></i>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gray-800">Répondre à cette commande</h3>
            <p class="text-sm text-gray-500">Acceptez ou refusez cette commande</p>
          </div>
        </div>
      </div>
      
      <form method="POST" action="/fournisseur/commande/<%= commande.idcommande %>/respond" class="p-6 space-y-4">
        <div>
          <label for="responseStatut" class="block text-sm font-medium text-gray-700 mb-2">Votre réponse</label>
          <select name="statut" id="responseStatut" required 
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Choisir une réponse...</option>
            <option value="approuvee">Accepter la commande</option>
            <option value="refusee">Refuser la commande</option>
          </select>
        </div>
        
        <div id="motifContainer" class="hidden">
          <label for="motifrefus" class="block text-sm font-medium text-gray-700 mb-2">Motif du refus (obligatoire si refus)</label>
          <textarea name="motifrefus" id="motifrefus" rows="3" 
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Expliquez pourquoi vous refusez cette commande..."></textarea>
        </div>
        
        <div class="pt-4 border-t border-gray-200 flex justify-end">
          <button type="submit" 
            class="bg-emerald-600 text-white font-semibold px-6 py-2 rounded-lg hover:bg-emerald-700 transition-colors inline-flex items-center">
            <i class="fas fa-paper-plane mr-2"></i>
            Envoyer la réponse
          </button>
        </div>
      </form>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
      const statusSelect = document.getElementById('responseStatut');
      const motifContainer = document.getElementById('motifContainer');
      const motifTextarea = document.getElementById('motifrefus');
      
      if (statusSelect) {
        statusSelect.addEventListener('change', function() {
          if (this.value === 'refusee') {
            motifContainer.classList.remove('hidden');
            motifTextarea.required = true;
            motifTextarea.focus();
          } else {
            motifContainer.classList.add('hidden');
            motifTextarea.required = false;
          }
        });
      }
    });
    </script>
  <% } %>

  <!-- Actions -->
  <div class="flex justify-between items-center">
    <a href="/fournisseur/dashboard" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
      <i class="fas fa-arrow-left mr-2"></i>Retour au dashboard
    </a>
    
    <div class="space-x-4">
      <% if (['approuvee', 'en_cours'].includes(commande.statut)) { %>
        <form method="POST" action="/fournisseur/commande/<%= commande.idcommande %>/confirm-delivery" class="inline"
          onsubmit="return confirm('Confirmer l\'expédition (départ de livraison) de cette commande ?');">
          <button type="submit" class="bg-amber-600 text-white px-4 py-2 rounded-lg hover:bg-amber-700 font-semibold">
            <i class="fas fa-truck mr-2"></i>Confirmer l'expédition
          </button>
        </form>
      <% } %>
      <% if (commande.statut === 'en_cours_de_livraison') { %>
        <span class="inline-flex items-center px-4 py-2 rounded-lg bg-amber-100 text-amber-800 font-medium">
          <i class="fas fa-shipping-fast mr-2"></i>En cours de livraison
        </span>
      <% } %>
      <% if (commande.statut === 'livree') { %>
        <span class="inline-flex items-center px-4 py-2 rounded-lg bg-emerald-100 text-emerald-800 font-medium">
          <i class="fas fa-check-circle mr-2"></i>Livrée & Réceptionnée
        </span>
      <% } %>
      
      <button onclick="printOrder()" class="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700">
        <i class="fas fa-print mr-2"></i>Imprimer
      </button>
      
      <button onclick="exportOrder()" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
        <i class="fas fa-download mr-2"></i>Exporter PDF
      </button>
    </div>
  </div>
</div>

<script>
function confirmDelivery() {
  console.log('🔍 Début de confirmDelivery pour commande ID:', <%= commande.idcommande %>);
  
  if (confirm('Êtes-vous sûr de vouloir confirmer la livraison de cette commande ?')) {
    console.log('✅ Confirmation utilisateur reçue');
    
    // Envoyer la requête POST pour confirmer la livraison
    const url = '/fournisseur/commande/<%= commande.idcommande %>/confirm-delivery';
    console.log('🌐 Envoi requête vers:', url);
    
    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({})
    })
    .then(response => {
      console.log('📡 Réponse reçue, status:', response.status);
      return response.json();
    })
    .then(data => {
      console.log('📊 Données reçues:', data);
      
      if (data.success) {
        alert('Livraison confirmée avec succès');
        console.log('✅ Succès, rechargement de la page');
        window.location.reload();
      } else {
        console.error('❌ Erreur serveur:', data.error);
        alert('Erreur: ' + (data.error || 'Impossible de confirmer la livraison'));
      }
    })
    .catch(error => {
      console.error('💥 Erreur fetch:', error);
      alert('Erreur lors de la confirmation de la livraison');
    });
  } else {
    console.log('❌ Confirmation utilisateur annulée');
  }
}

function printOrder() {
  window.print();
}

function exportOrder() {
  const commande = <%- JSON.stringify(commande) %>;
  
  // Create a simple text representation
  let content = `COMMANDE N°${commande.idcommande}\n\n`;
  content += `Fournisseur: ${commande.raisonsocial || 'N/A'}\n`;
  content += `Date: ${commande.datecreation || 'N/A'}\n`;
  content += `Statut: ${commande.statut || 'N/A'}\n`;
  content += `Montant: ${commande.montant != null ? formatMoney(commande.montant) : 'N/A'}\n`;
  content += `Détails: ${commande.details || 'Aucun détail disponible'}\n`;
  
  // Create blob and download
  const blob = new Blob([content], { type: 'text/plain;charset=utf-8;' });
  const link = document.createElement('a');
  const url = URL.createObjectURL(blob);
  link.setAttribute('href', url);
  link.setAttribute('download', `commande_${commande.idcommande}.txt`);
  link.style.visibility = 'hidden';
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}
</script>
