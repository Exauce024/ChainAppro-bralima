<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Confirmer l'expédition</h1>
    <p class="text-gray-600 mt-1">Commande n°<%= commande.idcommande %> — <%= commande.reference || 'Sans référence' %></p>
  </div>

  <% if (commande.statut === 'en_cours_de_livraison' || commande.statut === 'livree') { %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-green-900 text-sm font-medium mb-1">Expédition déjà enregistrée</p>
      <p class="text-green-800 text-sm">
        L'expédition de cette commande est déjà confirmée.
      </p>
    </div>
  <% } else { %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <p class="text-amber-900 text-sm font-medium mb-1">Départ de livraison</p>
      <p class="text-amber-800 text-sm">
        Vérifiez les articles ci-dessous, puis cliquez sur le bouton
        <strong>« Confirmer l'expédition »</strong> en bas de page pour valider l'envoi de la marchandise et générer le bon de transport.
      </p>
    </div>
  <% } %>

  <%- include('_lignes_commande_table') %>

  <div class="bg-white rounded-lg shadow p-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <a href="/fournisseur/commande/<%= commande.idcommande %>" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
      <i class="fas fa-arrow-left mr-2"></i>Retour aux détails
    </a>
    <% if (commande.statut !== 'en_cours_de_livraison' && commande.statut !== 'livree') { %>
      <form method="POST" action="/fournisseur/commande/<%= commande.idcommande %>/confirm-delivery"
        onsubmit="return confirm('Confirmer l\'expédition et le départ de la livraison de cette commande ?');">
        <button type="submit" class="bg-amber-600 text-white px-8 py-3 rounded-lg hover:bg-amber-700 font-semibold text-lg shadow-md">
          <i class="fas fa-truck mr-2"></i>Confirmer l'expédition
        </button>
      </form>
    <% } else { %>
      <a href="/fournisseur/dashboard" class="bg-emerald-600 text-white px-8 py-3 rounded-lg hover:bg-emerald-700 font-semibold text-lg shadow-md inline-block">
        <i class="fas fa-check-circle mr-2"></i>Retour au tableau de bord
      </a>
    <% } %>
  </div>
</div>
