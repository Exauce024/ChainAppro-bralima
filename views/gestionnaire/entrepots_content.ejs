<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Gestion des Entrepôts</h1>
    <p class="text-gray-600 mt-1">Consultez, ajoutez et gérez les emplacements physiques de stockage</p>
  </div>

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-check-circle text-green-500 mr-2"></i>
        <span class="text-green-700"><%= success %></span>
      </div>
    </div>
  <% } %>
  
  <% if (error && error.length > 0) { %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-exclamation-circle text-red-500 mr-2"></i>
        <span class="text-red-700"><%= error %></span>
      </div>
    </div>
  <% } %>

  <!-- Grid Layout: Table & Form -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- Left Column: Warehouses Table -->
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-800">Liste des Entrepôts</h2>
          <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">
            <%= entrepots.length %> entrepôt(s)
          </span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Entrepôt</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Matières stockées</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200" id="entrepotsTableBody">
              <% entrepots.forEach(e => { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <div class="flex-shrink-0 h-10 w-10 bg-purple-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-warehouse text-purple-600"></i>
                      </div>
                      <div class="ml-4">
                        <div class="text-sm font-medium text-gray-900"><%= e.nom %></div>
                        <div class="text-xs text-gray-500">ID: #<%= e.identret %></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full <%= e.nb_produits > 0 ? 'bg-indigo-100 text-indigo-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= e.nb_produits %> matière(s)
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <% if (e.quantite_totale > 0) { %>
                      <span class="text-gray-400 cursor-not-allowed" title="Impossible de supprimer un entrepôt contenant du stock.">
                        <i class="fas fa-trash-alt mr-1"></i>Supprimer
                      </span>
                    <% } else { %>
                      <a href="/gestionnaire/entrepots/delete/<%= e.identret %>" 
                         onclick="return confirm('Êtes-vous sûr de vouloir supprimer l\'entrepôt &quot;<%= e.nom %>&quot; ?');"
                         class="text-red-600 hover:text-red-900 transition-colors">
                        <i class="fas fa-trash-alt mr-1"></i>Supprimer
                      </a>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        
        <% if (entrepots.length === 0) { %>
          <div class="text-center py-12">
            <i class="fas fa-warehouse text-gray-300 text-5xl mb-4"></i>
            <p class="text-gray-500">Aucun entrepôt configuré en base de données.</p>
          </div>
        <% } %>
      </div>
    </div>
    
    <!-- Right Column: Add Warehouse Form -->
    <div class="space-y-6">
      <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Ajouter un entrepôt</h3>
        
        <form method="POST" action="/gestionnaire/entrepots/create" class="space-y-4">
          <div>
            <label for="nom" class="block text-sm font-medium text-gray-700 mb-2">Nom de l'entrepôt *</label>
            <input type="text" name="nom" id="nom" required 
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
                   placeholder="Ex: Hangar Malt B">
          </div>
          
          <button type="submit" class="w-full px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg shadow transition-colors flex items-center justify-center">
            <i class="fas fa-plus mr-2"></i>Créer l'entrepôt
          </button>
        </form>
      </div>
    </div>

  </div>
</div>
