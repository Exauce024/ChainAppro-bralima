<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Créer une Matière Première</h1>
    <p class="text-gray-600 mt-1">Ajouter une nouvelle matière première dans le système</p>
  </div>

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-check-circle text-green-500 mr-2"></i>
        <span class="text-green-700"><%= success %></span>
      </div>
    </div>
  <% } %>
  
  <% if (error && error.length > 0) { %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <div class="flex items-center">
        <i class="fas fa-exclamation-circle text-red-500 mr-2"></i>
        <span class="text-red-700"><%= error %></span>
      </div>
    </div>
  <% } %>

  <!-- Creation Form -->
  <div class="bg-white rounded-lg shadow">
    <div class="p-6">
      <form method="POST" action="/matieres/create" class="space-y-6">
        <!-- Product Information -->
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-medium text-gray-900 mb-4">Informations Produit</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Nom du produit *</label>
              <input type="text" 
                     name="libellé" 
                     required
                     placeholder="Ex: Carte SIM Standard"
                     class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
              <textarea name="description" 
                        rows="3"
                        placeholder="Description détaillée du produit..."
                        class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
            </div>
          </div>
        </div>


        <!-- Stock Thresholds -->
        <div>
          <h3 class="text-lg font-medium text-gray-900 mb-4">Seuils de Stock</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Seuil critique</label>
              <input type="number" 
                     name="seuilcritique" 
                     min="0"
                     placeholder="0"
                     class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
              <p class="text-xs text-gray-500 mt-1">Alerte urgente quand le stock atteint ce niveau</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Seuil d'alerte</label>
              <input type="number" 
                     name="seuilalerte" 
                     min="0"
                     placeholder="0"
                     class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
              <p class="text-xs text-gray-500 mt-1">Alerte de réapprovisionnement recommandé</p>
            </div>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-between items-center pt-6 border-t border-gray-200">
          <a href="/gestionnaire/stocks" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
            <i class="fas fa-arrow-left mr-2"></i>Retour aux stocks
          </a>
          <div class="space-x-4">
            <button type="reset" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
              <i class="fas fa-undo mr-2"></i>Réinitialiser
            </button>
            <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
              <i class="fas fa-save mr-2"></i>Créer la matière première
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('form');
  form.addEventListener('submit', function(e) {
    const libelle = document.querySelector('input[name="libellé"]').value;
    
    if (!libelle.trim()) {
      e.preventDefault();
      alert('Le nom du produit est obligatoire');
      return;
    }

    const scInput = document.querySelector('input[name="seuilcritique"]');
    const saInput = document.querySelector('input[name="seuilalerte"]');
    const sc = parseFloat(scInput.value) || 0;
    const sa = parseFloat(saInput.value) || 0;

    if (sc >= sa) {
      e.preventDefault();
      alert("Le seuil d'alerte doit obligatoirement être supérieur au seuil critique");
      
      // Highlight the fields in red
      scInput.classList.add('border-red-500', 'focus:ring-red-500');
      saInput.classList.add('border-red-500', 'focus:ring-red-500');
      
      // Remove red highlights on user input
      const resetBorders = () => {
        scInput.classList.remove('border-red-500', 'focus:ring-red-500');
        saInput.classList.remove('border-red-500', 'focus:ring-red-500');
      };
      scInput.addEventListener('input', resetBorders, { once: true });
      saInput.addEventListener('input', resetBorders, { once: true });
      
      return;
    }
  });
});
</script>
