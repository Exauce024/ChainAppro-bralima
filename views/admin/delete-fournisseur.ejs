<% /* views/admin/delete-fournisseur.ejs */ %>
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Supprimer le fournisseur – <%= fournisseur.raisonsocial %></h1>
    <p class="text-gray-600 mt-1">Êtes‑vous sûr de vouloir supprimer ce fournisseur ? Cette action est irréversible.</p>
  </div>

  <!-- Confirmation Card -->
  <div class="bg-white rounded-lg shadow p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div><strong>ID :</strong> <%= fournisseur.idfournisseur %></div>
      <div><strong>Raison Sociale :</strong> <%= fournisseur.raisonsocial %></div>
      <div><strong>Contact :</strong> <%= fournisseur.contact_nom || '---' %></div>
      <div><strong>Téléphone :</strong> <%= fournisseur.telephone %></div>
    </dl>
    <form method="POST" action="/admin/fournisseur/<%= fournisseur.idfournisseur %>/delete" class="mt-6 flex space-x-4">
      <a href="/admin/fournisseurs" class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400">Annuler</a>
      <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">
        <i class="fas fa-trash mr-1"></i> Confirmer la suppression
      </button>
    </form>
  </div>
</div>
