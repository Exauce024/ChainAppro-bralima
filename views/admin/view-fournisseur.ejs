<% /* views/admin/view-fournisseur.ejs */ %>
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Fournisseur – <%= fournisseur.raisonsocial %></h1>
    <p class="text-gray-600 mt-1">Détails du fournisseur</p>
  </div>

  <!-- Supplier Details -->
  <div class="bg-white rounded-lg shadow p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <h2 class="text-lg font-medium text-gray-700">Informations</h2>
      <ul class="mt-2 text-sm text-gray-600">
        <li><strong>ID :</strong> <%= fournisseur.idfournisseur %></li>
        <li><strong>Raison Sociale :</strong> <%= fournisseur.raisonsocial %></li>
        <li><strong>Libellé :</strong> <%= fournisseur.libellé %></li>
        <li><strong>Contact :</strong> <%= fournisseur.contact_nom || '---' %></li>
        <li><strong>Téléphone :</strong> <%= fournisseur.telephone %></li>
        <li><strong>Email :</strong> <%= fournisseur.email || '---' %></li>
        <li><strong>Adresse :</strong> <%= fournisseur.adresse %></li>
        <li><strong>Statut :</strong> <span class="px-2 inline-flex text-xs font-semibold rounded-full <%= fournisseur.statut === 'actif' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>"><%= fournisseur.statut %></span></li>
        <li><strong>Créé le :</strong> <%= fournisseur.date_creation ? new Date(fournisseur.date_creation).toLocaleDateString('fr-FR') : '---' %></li>
      </ul>
    </div>
    <div>
      <h2 class="text-lg font-medium text-gray-700">Matière fournie (optionnel)</h2>
      <% if (fournisseur.idmp) { %>
        <p class="mt-2 text-sm text-gray-600">Matière: <%= fournisseur.libellé_mp %> – Prix/kg: <%= fournisseur.prix_kg %> FC</p>
      <% } else { %>
        <p class="mt-2 text-sm text-gray-600">Aucune matière associée.</p>
      <% } %>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="flex space-x-4 pt-4">
    <a href="/admin/fournisseur/<%= fournisseur.idfournisseur %>/edit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
      <i class="fas fa-edit mr-1"></i> Modifier
    </a>
    <a href="/admin/fournisseur/<%= fournisseur.idfournisseur %>/delete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
      <i class="fas fa-trash mr-1"></i> Supprimer
    </a>
    <a href="/admin/fournisseurs" class="px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400">
      <i class="fas fa-arrow-left mr-1"></i> Retour à la liste
    </a>
  </div>
</div>
