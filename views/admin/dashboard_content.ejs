<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Administration</h1>
    <p class="text-gray-600 mt-1">Vue d'ensemble du système</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-users text-blue-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900"><%= users.length %></h3>
      <p class="text-sm text-gray-600">Utilisateurs</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-truck text-green-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900"><%= fournisseurs.length %></h3>
      <p class="text-sm text-gray-600">Fournisseurs</p>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-history text-purple-600 text-lg"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900"><%= typeof totalLogs !== 'undefined' ? totalLogs : logs.length %></h3>
      <p class="text-sm text-gray-600">Logs</p>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="bg-white rounded-lg shadow p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Actions rapides</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/admin/users" class="flex items-center p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
          <i class="fas fa-users text-blue-600"></i>
        </div>
        <div>
          <h3 class="font-medium text-gray-900">Gérer les utilisateurs</h3>
          <p class="text-sm text-gray-600">Ajouter, modifier, supprimer</p>
        </div>
      </a>
      
      <a href="/admin/fournisseurs" class="flex items-center p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-3">
          <i class="fas fa-truck text-green-600"></i>
        </div>
        <div>
          <h3 class="font-medium text-gray-900">Gérer les fournisseurs</h3>
          <p class="text-sm text-gray-600">Ajouter, modifier, supprimer</p>
        </div>
      </a>
      
      <a href="/admin/logs" class="flex items-center p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
        <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-3">
          <i class="fas fa-history text-purple-600"></i>
        </div>
        <div>
          <h3 class="font-medium text-gray-900">Voir les logs</h3>
          <p class="text-sm text-gray-600">Audit et activités</p>
        </div>
      </a>
    </div>
  </div>
</div>
