<% /* views/admin/edit-fournisseur.ejs */ %>
<div class="space-y-6">
  <!-- Page Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Modifier le fournisseur – <%= fournisseur.raisonsocial %></h1>
    <p class="text-gray-600 mt-1">Mettez à jour les informations du fournisseur</p>
  </div>

  <!-- Edit Form -->
  <div class="bg-white rounded-lg shadow p-6">
    <form method="POST" action="/admin/fournisseur/<%= fournisseur.idfournisseur %>/update" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="raisonsocial">Raison sociale *</label>
          <input type="text" id="raisonsocial" name="raisonsocial" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.raisonsocial %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="libellé">Libellé court</label>
          <input type="text" id="libellé" name="libellé" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.libellé %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="telephone">Téléphone *</label>
          <input type="tel" id="telephone" name="telephone" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.telephone %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
          <input type="email" id="email" name="email" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.email %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact_nom">Nom du contact</label>
          <input type="text" id="contact_nom" name="contact_nom" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.contact_nom %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="delai_livraison">Délai de livraison (jours)</label>
          <input type="number" id="delai_livraison" name="delai_livraison" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= fournisseur.delai_livraison %>">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1" for="adresse">Adresse</label>
          <textarea id="adresse" name="adresse" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"><%= fournisseur.adresse %></textarea>
        </div>
        <div class="md:col-span-2 border-t pt-4">
          <h2 class="text-lg font-medium text-gray-700 mb-2">Matière fournie (optionnel)</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="idmp">Matière première</label>
              <select id="idmp" name="idmp" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Sélectionner une matière</option>
                <% matieres.forEach(function(m) { %>
                  <option value="<%= m.idmp %>" <%= assoc && assoc.idmp == m.idmp ? 'selected' : '' %>><%= m.libellé %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="prix_kg">Prix par kilo (FC)</label>
              <input type="number" step="0.01" min="0" id="prix_kg" name="prix_kg" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" value="<%= assoc ? assoc.prix_kg : '' %>">
            </div>
          </div>
        </div>
      </div>
      <div class="flex justify-end space-x-4 pt-4">
        <a href="/admin/fournisseurs" class="px-4 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400">Annuler</a>
        <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
          <i class="fas fa-check mr-1"></i> Mettre à jour
        </button>
      </div>
    </form>
  </div>
</div>
